@{
    Layout = null;
    var firstName  = ViewBag.FirstName as string ?? "Değerli Misafirimiz";
    var lastName   = ViewBag.LastName  as string ?? "";
    var tourTitle  = ViewBag.TourTitle as string ?? "Turunuz";
    var bookingId  = ViewBag.BookingId as string ?? "—";
    var bookingDate = ViewBag.BookingDate != null
                      ? ((DateTime)ViewBag.BookingDate).ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
                      : "—";
    var personCount = ViewBag.PersonCount != null ? ViewBag.PersonCount.ToString() : "—";
    var email      = ViewBag.Email as string ?? "—";
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="tr">

@await Component.InvokeAsync("_HomeHeadComponentPartial")
@await Component.InvokeAsync("_DefaultHeaderComponentPartial")

<style>
  body { background: #f4f8f8; }

  .success-wrapper {
    min-height: 70vh;
    display: flex; align-items: center; justify-content: center;
    padding: 60px 16px;
  }

  .success-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 8px 40px rgba(13,158,143,.12);
    max-width: 560px; width: 100%;
    overflow: hidden;
    text-align: center;
  }

  /* Üst banner */
  .success-top {
    background: linear-gradient(135deg, #0d9e8f, #0a7d71);
    padding: 44px 32px 32px;
    position: relative;
  }
  .success-top::after {
    content: '';
    display: block;
    position: absolute; bottom: -18px; left: 0; right: 0;
    height: 36px;
    background: #fff;
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }
  .checkmark-circle {
    width: 72px; height: 72px; border-radius: 50%;
    background: rgba(255,255,255,.2);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
    border: 3px solid rgba(255,255,255,.5);
  }
  .checkmark-circle svg { width: 36px; height: 36px; color: #fff; }
  .success-top h2 { color: #fff; font-size: 22px; font-weight: 800; margin-bottom: 6px; }
  .success-top p  { color: rgba(255,255,255,.85); font-size: 14px; margin: 0; }

  /* İçerik */
  .success-body { padding: 36px 32px 28px; }

  .booking-ref {
    background: #e6f7f5;
    border-radius: 10px;
    padding: 12px 20px;
    margin-bottom: 24px;
    display: inline-block;
  }
  .booking-ref small { color: #0a7d71; font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
  .booking-ref span  { display: block; color: #0d9e8f; font-size: 16px; font-weight: 900; letter-spacing: .04em; }

  /* Detay tablosu */
  .detail-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; text-align: left; }
  .detail-table tr { border-bottom: 1px solid #f0f0f0; }
  .detail-table tr:last-child { border: none; }
  .detail-table td { padding: 10px 4px; font-size: 13px; }
  .detail-table td:first-child { color: #6b7f86; font-weight: 600; width: 42%; }
  .detail-table td:last-child  { color: #1a2e35; font-weight: 700; }

  /* Info kutusu */
  .info-box {
    background: #fffbea;
    border: 1px solid #f0c93a44;
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 13px;
    color: #7a6a00;
    margin-bottom: 24px;
    display: flex; align-items: flex-start; gap: 10px; text-align: left;
  }
  .info-box svg { flex-shrink: 0; color: #f0c93a; margin-top: 1px; }

  /* Butonlar */
  .btn-group-custom { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .btn-home {
    background: #0d9e8f; color: #fff;
    border: none; border-radius: 8px;
    padding: 12px 28px; font-size: 14px; font-weight: 700;
    cursor: pointer; text-decoration: none;
    transition: background .15s;
  }
  .btn-home:hover { background: #0a7d71; color: #fff; }
  .btn-tours {
    background: #e6f7f5; color: #0d9e8f;
    border: 2px solid #0d9e8f; border-radius: 8px;
    padding: 12px 28px; font-size: 14px; font-weight: 700;
    cursor: pointer; text-decoration: none;
    transition: all .15s;
  }
  .btn-tours:hover { background: #0d9e8f; color: #fff; }

  /* Confetti dots (dekoratif) */
  .confetti { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; overflow: hidden; }
  .dot {
    position: absolute; width: 8px; height: 8px; border-radius: 50%;
    opacity: .5; animation: fall 3s ease-in infinite;
  }
  @@keyframes fall {
    0%   { transform: translateY(-20px) rotate(0deg); opacity:.6; }
    100% { transform: translateY(120px) rotate(360deg); opacity:0; }
  }
</style>

<!-- BreadCrumb -->
<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(images/bg/bg1.jpg);">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(images/shape8.png);"></div>
    <div class="breadcrumb-outer">
        <div class="container">
            <div class="breadcrumb-content text-center">
                <h1 class="mb-3">Rezervasyon Onayı</h1>
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Anasayfa</a></li>
                        <li class="breadcrumb-item active">Rezervasyon Onayı</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>

<section class="bg-lgrey">
    <div class="success-wrapper">
        <div class="success-card">

            <!-- Üst yeşil banner -->
            <div class="success-top" style="position:relative;">
                <div class="confetti" id="confetti"></div>
                <div class="checkmark-circle">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </div>
                <h2>Rezervasyonunuz Alındı!</h2>
                <p>@firstName @lastName, kaydınız başarıyla oluşturuldu.</p>
            </div>

            <!-- İçerik -->
            <div class="success-body">

                <!-- Rezervasyon kodu -->
                <div class="booking-ref">
                    <small>Rezervasyon Kodu</small>
                    <span>@(!string.IsNullOrEmpty(bookingId) ? "#" + bookingId.Substring(0, Math.Min(8, bookingId.Length)).ToUpper() : "—")</span>
                </div>

                <!-- Detaylar -->
                <table class="detail-table">
                    <tr>
                        <td>Tur</td>
                        <td>@tourTitle</td>
                    </tr>
                    <tr>
                        <td>Tarih</td>
                        <td>@bookingDate</td>
                    </tr>
                    <tr>
                        <td>Kişi Sayısı</td>
                        <td>@personCount kişi</td>
                    </tr>
                    <tr>
                        <td>E-posta</td>
                        <td>@email</td>
                    </tr>
                    <tr>
                        <td>Durum</td>
                        <td>
                            <span style="background:#fff8e6;color:#f39c12;border-radius:6px;padding:2px 10px;font-size:12px;font-weight:700;">
                                ⏳ Onay Bekliyor
                            </span>
                        </td>
                    </tr>
                </table>

                <!-- Bilgi kutusu -->
                <div class="info-box">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <span>
                        Rezervasyonunuz incelendikten sonra <strong>@email</strong> adresine onay e-postası gönderilecektir.
                        Ödeme tur günü rehberinize yapılacaktır.
                    </span>
                </div>

                <!-- Butonlar -->
                <div class="btn-group-custom">
                    <a href="/" class="btn-home">
                        <i class="fa fa-home me-1"></i> Anasayfa
                    </a>
                    <a href="/Tour/TourList" class="btn-tours">
                        <i class="fa fa-map-marked-alt me-1"></i> Diğer Turlar
                    </a>
                </div>

            </div>
        </div>
    </div>
</section>
<div id="back-to-top"><a href="#"></a></div>

<script src="~/03_travelin_main_file/travelin/js/jquery-3.5.1.min.js"></script>
<script src="~/03_travelin_main_file/travelin/js/bootstrap.min.js"></script>
<script src="~/03_travelin_main_file/travelin/js/fontawesome.min.js"></script>
<script src="~/03_travelin_main_file/travelin/js/main.js"></script>

<script>
  // Küçük konfeti noktaları
  var colors = ['#0d9e8f','#f0c93a','#e74c3c','#3b82f6','#fff'];
  var container = document.getElementById('confetti');
  for (var i = 0; i < 18; i++) {
    var d = document.createElement('div');
    d.className = 'dot';
    d.style.left = (Math.random() * 100) + '%';
    d.style.top  = (Math.random() * 40) + '%';
    d.style.background = colors[Math.floor(Math.random() * colors.length)];
    d.style.animationDelay = (Math.random() * 2) + 's';
    d.style.animationDuration = (2 + Math.random() * 2) + 's';
    container.appendChild(d);
  }
</script>

</html>
