@model List<Project3Travelin.Dtos.CommantDtos.ResultCommentListByTourIdDto>

@if (Model != null && Model.Any())
{
    @foreach (var comment in Model)
    {
        <div class="comment-box">
            <div class="comment-image">
                <img style="width: 60px" src="https://w7.pngwing.com/pngs/223/244/png-transparent-computer-icons-avatar-user-profile-avatar-heroes-rectangle-black.png" alt="@comment.Name">
            </div>
            <div class="comment-content rounded">
                <h5 class="mb-1">@comment.Name</h5>
                <p class="comment-date">
                    @comment.CommentDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
                </p>
                <div class="comment-rate">
                    <div class="rating mar-right-15">
                        @{
                            int overall = (int)Math.Round(
                                (comment.Cleanliness + comment.Facilities +
                                 comment.ValueForMoney + comment.Service + comment.Location) / 5.0);
                            for (int i = 1; i <= 5; i++)
                            {
                                <span class="fa fa-star @(i <= overall ? "checked" : "")"></span>
                            }
                        }
                    </div>
                    <span class="comment-title">@comment.Headline</span>
                </div>
                <p class="comment">@comment.CommentDetail</p>
                <div class="row mt-2" style="font-size:12px; color:#888;">
                    <div class="col-4">Rehber: @comment.Cleanliness/5</div>
                    <div class="col-4">Ulaşım: @comment.Facilities/5</div>
                    <div class="col-4">Konaklama: @comment.ValueForMoney/5</div>
                    <div class="col-4">Yemek: @comment.Service/5</div>
                    <div class="col-4">Fiyat/Performans: @comment.Location/5</div>
                </div>
            </div>
        </div>
    }
}
else
{
    <p class="text-muted">Henüz yorum yapılmamış. İlk yorumu sen yap!</p>
}