<script>
function submitFilter() {
    // Dropdown'dan seçilen değeri hidden input'a kopyala
    document.getElementById('hiddenCity').value = 
        document.getElementById('cityDropdown').value;
    
    document.getElementById('hiddenMinPrice').value = 
        document.getElementById('minPriceInput').value;
    
    document.getElementById('hiddenMaxPrice').value = 
        document.getElementById('maxPriceInput').value;
    
    // Formu submit et
    document.getElementById('filterForm').submit();
}
</script>