@model List<Project3Travelin.Dtos.FaqDtos.ResultFaqDto>

<section class="faq-section">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <div class="d-flex justify-content-end position-relative mb-5 mb-lg-0">
          <img src="https://www.etstur.com/letsgo/wp-content/uploads/2025/06/01-arjantin-letsgo.png" alt="Hiking Tour" class="img-fluid rounded w-75 me-lg-4"/>
          <div class="tag-card">
            <strong>Güney Amerika Turları</strong><br/>
            <small class="text-muted"><i class="icon-location-pin theme1"></i> Arjantin - Şili</small>
          </div>
          <img src="https://www.egitimnoktasi.com.tr/assets/files/sayfalar/egitimnoktasi-yurtdisiegitim-sili-ulkerehberi-1.jpg" alt="Lake View" class="img-fluid stacked-img" style="width: 200px"/>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="section-title mb-6">
          <h5 class="mb-1 theme1"><i class="icon-plane theme1 fs-7"></i> SSS</h5>
          <h2 class="mb-1">Seyahat Hakkında <span class="theme">Merak Ettikleriniz</span></h2>
        </div>

        <div class="accordion faq-accordion" id="travelFaq">
          @for (int i = 0; i < Model.Count; i++)
          {
            <div class="accordion-item">
              <h2 class="accordion-header" id="heading_@i">
                <button
                  class="accordion-button @(i == 0 ? "" : "collapsed")"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#collapse_@i"
                  aria-expanded="@(i == 0 ? "true" : "false")"
                  aria-controls="collapse_@i">
                  @Model[i].Question
                </button>
              </h2>
              <div id="collapse_@i" class="accordion-collapse collapse @(i == 0 ? "show" : "")" aria-labelledby="heading_@i" data-bs-parent="#travelFaq">
                <div class="accordion-body">
                  @Model[i].Answer
                </div>
              </div>
            </div>
          }
        </div>
      </div>
    </div>
  </div>
</section>