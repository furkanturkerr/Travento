@model Project3Travelin.Dtos.SliderDtos.ResultSliderDto
<section class="banner overflow-hidden">
  <div class="slider">
    <div class="swiper-container">
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <div class="slide-inner">
            <div class="slide-image" style="background-image: url(@Model.Image1)"></div>
            <div class="soft-overlay"></div>
          </div>
        </div>
        <div class="swiper-slide">
          <div class="slide-inner">
            <div class="slide-image" style="background-image: url(@Model.Image2)"></div>
            <div class="soft-overlay"></div>
          </div>
        </div>
        <div class="swiper-slide">
          <div class="slide-inner">
            <div class="slide-image" style="background-image: url(@Model.Image3)"></div>
            <div class="soft-overlay"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="swiper-button-next"></div>
  <div class="swiper-button-prev"></div>

  <div class="banner-content position-absolute">
    <h1 class="mb-0">
      <a href="~/Tour/TourList" class="white">@Model.Title</a>
    </h1>

    <div class="banner-booking mt-3">
      @await Component.InvokeAsync("_HomeSearchBarComponentPartial")
    </div>
  </div>
</section>