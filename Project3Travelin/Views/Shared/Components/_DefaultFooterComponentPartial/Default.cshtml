@model Project3Travelin.Dtos.InstagramDtos.ResultInstagramDto
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
<style>
    .footer-lang {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .footer-lang a {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        color: rgba(255,255,255,0.7) !important;
        border: 1px solid rgba(255,255,255,0.2);
        text-decoration: none !important;
        transition: all 0.2s;
    }

    .footer-lang a:hover {
        color: #fff !important;
        border-color: rgba(255,255,255,0.6);
        background: rgba(255,255,255,0.1);
    }

    .footer-lang a.footer-lang-active {
        color: #fff !important;
        border-color: #1a9e96;
        background: #1a9e96;
    }
</style>
<footer class="pt-20 pb-4" style="background-image: url(03_travelin_main_file/travelin/images/background_pattern.png);">
    <div class="section-shape top-0" style="background-image: url(03_travelin_main_file/travelin/images/shape8.png);"></div>
    <!-- Instagram starts -->
    <div class="insta-main pb-10">
        <div class="container">
            <div class="insta-inner">
                <div class="follow-button">
                    <a href="@Model.Url" target="_blank">
                    <h5 class="m-0 rounded"><i class="fab fa-instagram"></i>@Localizer["Instagram'dan Takip Et"] </h5>
                    </a>
                </div>
                <div class="row attract-slider">
                    <div class="col-md-3 col-sm-6">
                        <div class="insta-image rounded">
                            <a href="gallery.html"><img style="width: 150px; height: 150px" src="@Model.Image1" alt="insta"></a>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="insta-image rounded">
                            <a href="gallery.html"><img style="width: 150px; height: 150px" src="@Model.Image2" alt="insta"></a>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="insta-image rounded">
                            <a href="gallery.html"><img style="width: 150px; height: 150px" src="@Model.Image3" alt="insta"></a>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="insta-image rounded">
                            <a href="gallery.html"><img style="width: 150px; height: 150px" src="@Model.Image4" alt="insta"></a>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="insta-image rounded">
                            <a href="gallery.html"><img style="width: 150px; height: 150px" src="@Model.Image5" alt="insta"></a>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="insta-image rounded">
                            <a href="gallery.html"><img style="width: 150px; height: 150px" src="@Model.Image6" alt="insta"></a>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="insta-image rounded">
                            <a href="gallery.html"><img style="width: 150px; height: 150px" src="@Model.Image7" alt="insta"></a>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="insta-image rounded">
                            <a href="gallery.html"><img style="width: 150px; height: 150px" src="@Model.Image8" alt="insta"></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Instagram ends -->
    <div class="footer-upper pb-4">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 col-md-6 col-sm-12 mb-4 pe-4">
                    <div class="footer-about">
                        <img src="~/03_travelin_main_file/travelin/images/logo-white.png" alt="">
                        <p class="mt-3 mb-3 white">
                            @Localizer["Hayalinizdeki seyahati gerçeğe dönüştürmek için yola çıktık. Kültür turlarından doğa kaçamaklarına, yurt içi ve yurt dışı rotalarda unutulmaz deneyimler sunuyoruz. Alanında uzman rehberlerimiz, güvenli ulaşım ve özenle planlanmış programlarımızla her detayı sizin için düşünüyoruz."] 
                        </p>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 col-sm-12 mb-4">
                    <div class="footer-links">
                        <h3 class="white">@Localizer["Hızlı Linkler"]</h3>
                        <ul>
                            <li><a href="#about">@Localizer["Hakkımızda"]</a></li>
                            <li><a href="~/Tour/TourList">@Localizer["Tur Listesi"]</a></li>
                            <li><a href="~/iletisim">@Localizer["İletişim"]</a></li>
                            <li><a href="~/rezervasyon">@Localizer["Rezervasyon Yap"]</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 col-sm-12 mb-4">
                    <div class="footer-links">
                        
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                    <div class="footer-links">
                        <h3 class="white">@Localizer["Bültenimize Abone Olun"]</h3>
                        <div class="newsletter-form">
                            <p class="mb-3">
                                @Localizer["Kampanyalar, yeni tur rotaları ve özel indirimlerden ilk siz haberdar olun."]
                            </p>
                            <form action="#" method="get" accept-charset="utf-8" class="border-0 d-flex align-items-center">
                                <input type="text" placeholder="@Localizer["E-posta Adresiniz"]">
                                <button class="nir-btn ms-2">@Localizer["Abone Ol"]</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="row footer-pay align-items-center justify-content-between text-lg-start text-center">
               
                    <div class="col-lg-4 footer-payment-nav mb-4">
                        <ul class="d-flex align-items-center">
                            <li class="me-2">
                                <div class="footer-lang">
                                    <a href="@(Context.Request.Path)?culture=tr-TR" class="@(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "tr" ? "footer-lang-active" : "")">
                                        <span>🇹🇷</span> Türkçe
                                    </a>
                                    <a href="@(Context.Request.Path)?culture=en-US" class="@(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "en" ? "footer-lang-active" : "")">
                                        <span>🇬🇧</span> English
                                    </a>
                                    <a href="@(Context.Request.Path)?culture=de-DE" class="@(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "de" ? "footer-lang-active" : "")">
                                        <span>🇩🇪</span> Deutsch
                                    </a>
                                    <a href="@(Context.Request.Path)?culture=fr-FR" class="@(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "fr" ? "footer-lang-active" : "")">
                                        <span>🇫🇷</span> Français
                                    </a>
                                    <a href="@(Context.Request.Path)?culture=ru-RU" class="@(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "ru" ? "footer-lang-active" : "")">
                                        <span>🇷🇺</span> Русский
                                    </a>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="footer-payment">
        <div class="container">
            
        </div>
    </div>

    <div class="footer-copyright">
        <div class="container">
            <div class="copyright-inner rounded p-3 d-md-flex align-items-center justify-content-between">
                <div class="copyright-text">
                    <p class="m-0 white">2026 Travento.</p>
                </div>
                <div class="social-links">
                    <ul>
                        <li><a href="#"><i class="fab fa-facebook" aria-hidden="true"></i></a></li>
                        <li><a href="#"><i class="fab fa-twitter" aria-hidden="true"></i></a></li>
                        <li><a href="#"><i class="fab fa-instagram" aria-hidden="true"></i></a></li>
                        <li><a href="#"><i class="fab fa-linkedin" aria-hidden="true"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div id="particles-js"></div>
</footer>