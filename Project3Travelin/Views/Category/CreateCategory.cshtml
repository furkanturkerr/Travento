@model Project3Travelin.Dtos.CategoryDtos.CreateCategoryDto

@{
    Layout = null;
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container">
    <br/>
    <form method="post">
        <label>Kategori Adı</label>
        <input type="text" asp-for="CategoryName" class="form-control"/>
        <br/>
        <label>Kategori Icon Url</label>
        <input type="text" asp-for="IconUrl" class="form-control"/>
        <br/>
        <button class="btn btn-primary">Kaydet</button>
    </form>
</div>