@model Project3Travelin.Dtos.TourDtos.CreateTourDto

@{
    Layout = null;
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container">
    <br/>
    <form method="post">
        <label>Tur Başlığı</label>
        <input type="text" asp-for="Title" class="form-control"/>
        <br/>
        <label>Tur Kapasitesi</label>
        <input type="number" asp-for="Capacity" class="form-control"/>
        <br/>
        <label>Şehir</label>
        <input type="text" asp-for="City" class="form-control"/>
        <br/>
        <label>Ülke</label>
        <input type="text" asp-for="Country" class="form-control"/>
        <br/>
        <label>Tur Gece Gündüz</label>
        <input type="text" asp-for="DayNight" class="form-control"/>
        <br/>
        <label>Tur Tarihi</label>
        <input type="date" asp-for="TourDate" class="form-control"/>
        <br/>
        <label>Tur Görsel</label>
        <input type="text" asp-for="ImageUrl" class="form-control"/>
        <br/>
        <label>Tur Açıklaması</label>
        <textarea class="form-control" asp-for="Description" rows="5"></textarea>
        <br/>
        <button class="btn btn-primary">Kaydet</button>
    </form>
</div>

