@using Microsoft.AspNetCore.Mvc.RazorPages
@model System.Collections.Generic.List<Project3Travelin.Dtos.TourDtos.ResultTourDto>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    Layout = null;
    int currentPage = int.Parse(Context.Request.Query["page"].FirstOrDefault() ?? "1");
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="zxx">

@await Component.InvokeAsync("_TourHeadComponentPartial")

@await Component.InvokeAsync("_DefaultHeaderComponentPartial")
   

@await Component.InvokeAsync("_TourBreadcrumbComponentPartial")

    <section class="trending pt-6 pb-0 bg-lgrey">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="list-results d-flex align-items-center justify-content-between">
                    <div class="list-results-sort">
                        <p class="m-0">
                            @Localizer["Toplam"] @ViewBag.TotalCount @Localizer["tur"],
                            @Localizer["Sayfa"] @ViewBag.CurrentPage / @ViewBag.TotalPages
                        </p>
                    </div>
                </div>

                <div class="destination-list">
                    @foreach (var tour in Model)
                    {
                        <div class="trend-full bg-white rounded box-shadow overflow-hidden p-4 mb-4">
                            <div class="row">
                                <div class="col-lg-4 col-md-3">
                                    <div class="trend-item2 rounded">
                                        <a href="/Tour/TourDetail/@tour.TourId"
                                           style="background-image: url(@tour.ImageUrl);"></a>
                                        <div class="color-overlay"></div>
                                    </div>
                                </div>
                                <div class="col-lg-5 col-md-6">
                                    <div class="trend-content position-relative text-md-start text-center">
                                        <small>@tour.DayNight</small>
                                        <h3 class="mb-1">
                                            <a asp-controller="Tour" asp-action="TourDetail" asp-route-tourId="@tour.TourId" >@tour.Title</a>
                                        </h3>
                                        <h6 class="theme mb-0">
                                            <i class="icon-location-pin"></i> @tour.City, @tour.Country
                                        </h6>
                                        <p class="mt-4 mb-0">
                                            @Localizer["Kapasite"]: @tour.Capacity @Localizer["kişi"] <br>
                                            <span class="theme">@tour.TourDate.ToString("dd MMM yyyy")</span>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-3">
                                    <div class="trend-content text-md-end text-center">
                                        <div class="trend-price my-2">
                                            <span class="mb-0"></span>
                                            <h3 class="mb-0">@tour.Price.ToString("C0")</h3>
                                            <small>@Localizer["Başlayan Fiyatlarla"]</small>
                                        </div>
                                        <a asp-controller="Tour" asp-action="TourDetail" asp-route-tourId="@tour.TourId" class="nir-btn">@Localizer["Detay"]</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!Model.Any())
                    {
                        <div class="text-center p-5">
                            <h4>Sonuç bulunamadı.</h4>
                            <a href="/Tour/TourList" class="nir-btn mt-3">Tüm Turları Göster</a>
                        </div>
                    }
                </div>
                @if (!Model.Any())
                {
                    <div class="text-center p-5">
                        <h4>Sonuç bulunamadı.</h4>
                        <a href="/Tour/TourList" class="nir-btn mt-3">Tüm Turları Göster</a>
                    </div>
                }

                <!-- PAGINATION -->
                @if (ViewBag.TotalPages > 1)
                {
                    <div class="d-flex justify-content-center align-items-center my-4" style="gap:8px;">

                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="/Tour/TourList?city=@ViewBag.City&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice&page=@(ViewBag.CurrentPage - 1)"
                               class="nir-btn">« @Localizer["Önceki"]</a>
                        }

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <a href="/Tour/TourList?city=@ViewBag.City&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice&page=@i"
                                   class="nir-btn">@i</a>
                            }
                            else
                            {
                                <a href="/Tour/TourList?city=@ViewBag.City&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice&page=@i"
                                   class="nir-btn" style="background:#6c757d;">@i</a>
                            }
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="/Tour/TourList?city=@ViewBag.City&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice&page=@(ViewBag.CurrentPage + 1)"
                               class="nir-btn">@Localizer["Sonraki"] »</a>
                        }

                    </div>
                }
            </div>
            <div class="col-lg-4 ps-lg-4">
                <div class="sidebar-sticky">
                    <div class="list-sidebar">
                        <div class="sidebar-item mb-4">
                            <h3>@Localizer["Filtrele"]</h3>
                            <form method="get" asp-controller="Tour" asp-action="TourList" id="filterForm">

                                <input type="hidden" name="city" id="hiddenCity" value="@ViewBag.City">
                                <input type="hidden" name="minPrice" id="hiddenMinPrice" value="@ViewBag.MinPrice">
                                <input type="hidden" name="maxPrice" id="hiddenMaxPrice" value="@ViewBag.MaxPrice">

                                <div class="mb-3">
                                    <label class="mb-1"><strong>@Localizer["Şehir"]</strong></label>
                                    <select id="cityDropdown" class="form-control">
                                        <option value="">-- @Localizer["Tüm Şehirler"] --</option>
                                        @foreach (var c in ViewBag.Cities as List<string> ?? new List<string>())
                                        {
                                            if (ViewBag.City == c)
                                            {
                                                <option value="@c" selected>@c</option>
                                            }
                                            else
                                            {
                                                <option value="@c">@c</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="mb-1"><strong>@Localizer["Min Fiyat"] ($)</strong></label>
                                    <input type="number" id="minPriceInput" class="form-control"
                                           placeholder="0" value="@ViewBag.MinPrice">
                                </div>
                                <div class="mb-3">
                                    <label class="mb-1"><strong>@Localizer["Max Fiyat"] ($)</strong></label>
                                    <input type="number" id="maxPriceInput" class="form-control"
                                           placeholder="9999" value="@ViewBag.MaxPrice">
                                </div>

                                <button type="button" onclick="submitFilter()" class="nir-btn w-100 mb-2">
                                    @Localizer["Filtrele"]
                                </button>
                                <a href="/Tour/TourList" class="btn btn-outline-secondary w-100">@Localizer["Temizle"]</a>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Component.InvokeAsync("_TourVideoComponentPartial")

@await Component.InvokeAsync("_DefaultFooterComponentPartial")

    <div id="back-to-top">
        <a href="#"></a>
    </div>
    
    <div id="search1">
        <button type="button" class="close">×</button>
        <form>
            <input type="search" value="" placeholder="type keyword(s) here" />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>

    @await Component.InvokeAsync("_TourScriptComponentPartial")
    </html>
    