                                        @if (avg != null && avg.Overall >= 4) { <text>"Mükemmel"</text> }
                                        else if (avg != null && avg.Overall >= 3) { <text>"Çok İyi"</text> }
                                        else if (avg != null && avg.Overall >= 2) { <text>"İyi"</text> }
                                        else { <text>"Henüz Yorum Yok"</text> }
                                    </h4>
                                    <p class="mb-0 white font-italic">@(avg?.TotalReviews ?? 0) Yorum</p>
                                </div>
                            </div>
