<script src="~/03_travelin_main_file/travelin/js/custom-accordian.js"></script>
<script src="~/03_travelin_main_file/travelin/js/custom-nav.js"></script>
<script src="~/03_travelin_main_file/travelin/js/custom-navscroll.js"></script>

<script>
    $(document).ready(function () {

        // Her yıldız grubu için ayrı ayrı çalış
        $('.star-rating').each(function () {
            var container = $(this);
            var field = container.data('field');
            var stars = container.find('.star');

            stars.on('mouseover', function () {
                var val = $(this).data('value');
                stars.each(function () {
                    $(this).toggleClass('hover', $(this).data('value') <= val);
                });
            });

            stars.on('mouseout', function () {
                stars.removeClass('hover');
            });

            stars.on('click', function () {
                var val = $(this).data('value');
                stars.each(function () {
                    $(this).toggleClass('active', $(this).data('value') <= val);
                });
                $('input[name="' + field + '"]').val(val);
            });
        });

        // Smooth scroll
        $('.smooth-scroll').on('click', function (e) {
            e.preventDefault();
            var target = $(this).attr('href');
            $('html, body').animate({
                scrollTop: $(target).offset().top - 80
            }, 600);
            $('#tabs li').removeClass('active');
            $(this).parent().addClass('active');
        });

        $(window).on('scroll', function () {
            var scrollPos = $(document).scrollTop();
            $('#tabs a').each(function () {
                var target = $($(this).attr('href'));
                if (target.length) {
                    if (target.offset().top - 100 <= scrollPos &&
                        target.offset().top + target.height() > scrollPos) {
                        $('#tabs li').removeClass('active');
                        $(this).parent().addClass('active');
                    }
                }
            });
        });
    });
</script>


