                                </div>
                            </div>
                        </div>

                        <div class="description-images mb-4">
                            <img src="@Model.ImageUrl" alt="" class="w-100 rounded">
                        </div>

                        <div class="description mb-2">
                            <h4>Açıklama</h4>
                            <p>@Model.Description</p>
                        </div>

                        <div class="tour-includes mb-4">
                            <table>
                                <tbody>
                                <tr>
                                    <td><i class="fa fa-clock-o pink mr-1" aria-hidden="true"></i> @Model.DayNight</td>
                                    <td><i class="fa fa-group pink mr-1" aria-hidden="true"></i> Max People : @Model.Capacity</td>
                                    <td><i class="fa fa-calendar pink mr-1" aria-hidden="true"></i> @Model.TourDate</td>
                                </tr>
                                <tr>
                                    <td><i class="fa fa-user pink mr-1" aria-hidden="true"></i> Min Yaş : 10+</td>
                                    <td><i class="fa fa-map-signs pink mr-1" aria-hidden="true"></i> Havalimanı Transferi</td>
                                    <td><i class="fa fa-file-alt pink mr-1" aria-hidden="true"></i> Dil - İngilizce</td>
                                </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="description mb-2">
                            <div class="row">
                                <div class="col-lg-6 col-md-6 mb-2">
                                    <div class="desc-box bg-grey p-4 rounded">
                                        <h5 class="mb-2">Gidiş & Dönüş Lokasyonu</h5>
                                        <p class="mb-0">John F.K. Uluslararası Havalimanı (Google Haritalar)</p>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6 mb-2">
                                    <div class="desc-box bg-grey p-4 rounded">
                                        <h5 class="mb-2">Oda Bilgisi</h5>
                                        <p class="mb-0">4 Yatak Odası</p>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6 mb-2">
                                    <div class="desc-box bg-grey p-4 rounded">
                                        <h5 class="mb-2">Hareket Saati</h5>
                                        <p class="mb-0">Uçuş Saatinden 3 Saat Önce</p>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6 mb-2">
                                    <div class="desc-box bg-grey p-4 rounded">
                                        <h5 class="mb-2">Tur Süresi</h5>
                                        <p class="mb-0">@Model.DayNight</p>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6 mb-2">
                                    <div class="desc-box bg-grey p-4 rounded">
                                        <h5 class="mb-2">Fiyata Dahil Olan Hizmetler</h5>
                                        <ul>
                                            <li class="d-block pb-1"><i class="fa fa-check pink mr-1"></i> Uçak Biletleri</li>
                                            <li class="d-block pb-1"><i class="fa fa-check pink mr-1"></i> 3 Gece Otel Konaklaması</li>
                                            <li class="d-block pb-1"><i class="fa fa-check pink mr-1"></i> Profesyonel Rehberlik Hizmeti</li>
                                            <li class="d-block"><i class="fa fa-check pink mr-1"></i> Müze ve Ören Yeri Giriş Ücretleri</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6 mb-2">
                                    <div class="desc-box bg-grey p-4 rounded">
                                        <h5 class="mb-2">Fiyata Dahil Olmayan Hizmetler</h5>
                                        <ul>
                                            <li class="d-block pb-1"><i class="fa fa-close pink mr-1"></i> Rehber Bahşişleri</li>
                                            <li class="d-block pb-1"><i class="fa fa-close pink mr-1"></i> Şoför Bahşişleri</li>
                                            <li class="d-block pb-1"><i class="fa fa-close pink mr-1"></i> Kişisel Harcamalar</li>
                                            <li class="d-block"><i class="fa fa-close pink mr-1"></i> Oda Servisi Ücretleri</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
