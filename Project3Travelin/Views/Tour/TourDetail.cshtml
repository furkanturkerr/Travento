                                </iframe>
                            </div>
                        </div>
                    </div>

                    <!-- DEĞERLENDİRMELER -->
                    <div id="single-review" class="single-review mb-4">
                        <h4>Değerlendirmeler</h4>
                        <div class="row d-flex align-items-center">
                            <div class="col-lg-4 col-md-4">
                                <div class="review-box bg-title text-center py-4 p-2 rounded">
