@model Project3Travelin.Dtos.TourDtos.GetTourByIdDto

@{
Layout = null;
}

@using Project3Travelin.Dtos.TourTineraryDtos
@using Project3Travelin.Dtos.CommantDtos

@{
var itinerary = ViewBag.Itinerary as List<ResultTineraryListByTourIdDto>;
var avg = ViewBag.ReviewAverage as ReviewAverageDto;

double cleanPct    = avg != null ? Math.Round(avg.Cleanliness   / 5.0 * 100) : 0;
double facilPct    = avg != null ? Math.Round(avg.Facilities    / 5.0 * 100) : 0;
double valuePct    = avg != null ? Math.Round(avg.ValueForMoney / 5.0 * 100) : 0;
double servicePct  = avg != null ? Math.Round(avg.Service       / 5.0 * 100) : 0;
double locationPct = avg != null ? Math.Round(avg.Location      / 5.0 * 100) : 0;
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="zxx">

<style>
    .star-rating {
        display: flex;
        gap: 4px;
        cursor: pointer;
    }
    .star-rating .star {
        font-size: 32px;
        color: #ccc;
        transition: color 0.2s;
        user-select: none;
    }
    .star-rating .star.active,
    .star-rating .star.hover {
        color: #f5a623;
    }
</style>

@await Component.InvokeAsync("_TourHeadComponentPartial")

