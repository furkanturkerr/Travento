</div>

@await Component.InvokeAsync("_DefaultHeaderComponentPartial")

<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(@Model.ImageUrl);">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(~/03_travelin_main_file/travelin/images/shape8.png);"></div>
    <div class="breadcrumb-outer">
        <div class="container">
            <div class="breadcrumb-content text-center">
                <h1 class="mb-3">@Model.Title</h1>
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="#">Anasayfa</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Tur Listesi</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>

<section class="trending pt-6 pb-0 bg-lgrey">
