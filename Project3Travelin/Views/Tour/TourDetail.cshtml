                                                 style="width:@facilPct%">
                                                <span class="sr-only">@facilPct% Complete</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="progress-item mb-1">
                                        <p class="mb-0">Para Değeri</p>
                                        <div class="progress rounded">
                                            <div class="progress-bar bg-theme" role="progressbar"
                                                 aria-valuenow="@valuePct" aria-valuemin="0" aria-valuemax="100"
                                                 style="width:@valuePct%">
                                                <span class="sr-only">@valuePct% Complete</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="progress-item mb-1">
                                        <p class="mb-0">Hizmet</p>
                                        <div class="progress rounded">
                                            <div class="progress-bar bg-theme" role="progressbar"
                                                 aria-valuenow="@servicePct" aria-valuemin="0" aria-valuemax="100"
                                                 style="width:@servicePct%">
                                                <span class="sr-only">@servicePct% Complete</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="progress-item">
                                        <p class="mb-0">Konum</p>
                                        <div class="progress rounded">
                                            <div class="progress-bar bg-theme" role="progressbar"
                                                 aria-valuenow="@locationPct" aria-valuemin="0" aria-valuemax="100"
                                                 style="width:@locationPct%">
                                                <span class="sr-only">@locationPct% Complete</span>
                                            </div>
