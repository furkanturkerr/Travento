@model List<Project3Travelin.Dtos.BannerDtos.ResultBannerDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
    var banner = Model?.FirstOrDefault();
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --warning: #f39c12;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 4px 24px rgba(13,158,143,.10); --radius: 16px;
  }

  .page-breadcrumb { margin-bottom: 28px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; }
  .breadcrumb-item.active { color: var(--muted); }

  .btn-add {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--teal); color: #fff; border: none;
    padding: 10px 20px; border-radius: 8px;
    font-weight: 700; font-size: 14px; cursor: pointer;
    transition: background .2s, transform .15s; text-decoration: none;
    box-shadow: 0 4px 14px rgba(13,158,143,.25);
  }
  .btn-add:hover { background: var(--teal-dark); transform: translateY(-1px); color: #fff; }
  .btn-add.disabled { background: #b2d8d4; box-shadow: none; cursor: not-allowed; pointer-events: none; opacity: .7; }

  .info-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--teal-light); color: var(--teal);
    border-radius: 20px; padding: 5px 12px;
    font-size: 12px; font-weight: 600; margin-bottom: 20px;
  }

  /* ── Empty ── */
  .empty-card {
    background: var(--white); border-radius: var(--radius);
    border: 2px dashed var(--border);
    padding: 72px 32px; text-align: center; color: var(--muted);
  }
  .empty-card svg { opacity: .2; margin-bottom: 18px; }
  .empty-card h5 { font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .empty-card p  { font-size: 14px; margin-bottom: 24px; }

  /* ── Banner card ── */
  .banner-card {
    background: var(--white); border-radius: var(--radius);
    box-shadow: var(--shadow); border: 1px solid var(--border);
    overflow: hidden;
  }

  /* Hero */
  .banner-hero {
    position: relative;
    height: 320px;
    overflow: hidden;
    background: #0a1628;
  }
  .banner-hero img {
    width: 100%; height: 100%; object-fit: cover;
    opacity: .72; display: block;
  }
  .banner-hero .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,.3) 0%, rgba(0,0,0,.55) 100%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 24px;
  }
  .banner-hero .h-subtitle {
    color: rgba(255,255,255,.8); font-size: 13px; font-weight: 600;
    letter-spacing: .08em; margin-bottom: 10px;
    text-shadow: 0 1px 4px rgba(0,0,0,.4);
  }
  .banner-hero .h-title {
    color: #fff; font-size: 28px; font-weight: 900;
    text-shadow: 0 3px 12px rgba(0,0,0,.5);
    margin: 0 0 14px; line-height: 1.2;
  }
  .banner-hero .h-desc {
    color: rgba(255,255,255,.75); font-size: 13px;
    max-width: 500px; line-height: 1.6; margin: 0;
    text-shadow: 0 1px 4px rgba(0,0,0,.3);
  }
  /* Play button */
  .play-btn {
    width: 62px; height: 62px; border-radius: 50%;
    background: var(--teal); border: 3px solid rgba(255,255,255,.5);
    display: flex; align-items: center; justify-content: center;
    margin: 14px auto;
    box-shadow: 0 0 0 10px rgba(13,158,143,.2);
  }
  .play-btn svg { color: #fff; margin-left: 3px; }
  /* Video URL badge */
  .video-badge {
    position: absolute; top: 14px; left: 14px;
    background: rgba(0,0,0,.55); color: #fff;
    font-size: 11px; font-weight: 700; padding: 4px 10px;
    border-radius: 6px; backdrop-filter: blur(4px);
    display: flex; align-items: center; gap: 5px;
  }

  /* Card body */
  .card-body-inner { padding: 24px 28px; }
  .banner-title { font-size: 20px; font-weight: 900; color: var(--text); margin: 0 0 6px; }
  .banner-subtitle { font-size: 13px; color: var(--teal); font-weight: 600; margin: 0 0 8px; }
  .banner-desc { font-size: 13px; color: var(--muted); line-height: 1.6; margin: 0 0 18px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .meta-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }
  .meta-chip { display: inline-flex; align-items: center; gap: 5px; background: var(--teal-light); color: var(--teal); border-radius: 20px; padding: 4px 12px; font-size: 12px; font-weight: 700; }

  .divider { border: none; border-top: 1px solid var(--border); margin: 0 0 20px; }

  .action-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .id-text { font-size: 11px; color: var(--muted); font-family: monospace; }

  .action-btns { display: flex; gap: 10px; }
  .action-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 18px; border-radius: 9px; border: none;
    font-size: 13px; font-weight: 700; cursor: pointer;
    transition: background .15s, transform .15s; text-decoration: none;
  }
  .action-btn svg { width: 15px; height: 15px; }
  .btn-edit { background: #fff8e6; color: var(--warning); }
  .btn-edit:hover { background: var(--warning); color: #fff; transform: translateY(-1px); }
  .btn-del  { background: #fdecea; color: var(--danger); }
  .btn-del:hover  { background: var(--danger); color: #fff; transform: translateY(-1px); }
</style>

<!-- Breadcrumb -->
<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item active">Banner Alanı</li>
  </ol>

  @if (banner == null)
  {
    <a href="/Admin/Banner/CreateBanner" class="btn-add">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Banner Ekle
    </a>
  }
  else
  {
    <span class="btn-add disabled" title="Yalnızca 1 banner eklenebilir">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Banner Ekle
    </span>
  }
</nav>

<div class="info-chip">
  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
    <circle cx="12" cy="12" r="10"/>
    <line x1="12" y1="8" x2="12" y2="12"/>
    <line x1="12" y1="16" x2="12.01" y2="16"/>
  </svg>
  Bu bölümde yalnızca 1 banner tanımlanabilir.
</div>

@if (banner == null)
{
  <div class="empty-card">
    <svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <polygon points="5 3 19 3 19 21 12 17 5 21 5 3"/>
    </svg>
    <h5>Henüz banner eklenmedi</h5>
    <p>Ana sayfadaki tam ekran banner bölümünü buradan yönetin.</p>
    <a href="/Admin/Banner/CreateBanner" class="btn-add" style="display:inline-flex;">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Banner Ekle
    </a>
  </div>
}
else
{
  <div class="banner-card">

    <!-- Hero -->
    <div class="banner-hero">
      <img src="@banner.ImageUrl" alt="@banner.Title" />
      <div class="hero-overlay">
        <p class="h-subtitle">@banner.SubTitle</p>
        <h2 class="h-title">@banner.Title</h2>
        @if (!string.IsNullOrEmpty(banner.VideoUrl))
        {
          <div class="play-btn">
            <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
          </div>
        }
        <p class="h-desc">@banner.Description</p>
      </div>
      @if (!string.IsNullOrEmpty(banner.VideoUrl))
      {
        <div class="video-badge">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          Video mevcut
        </div>
      }
    </div>

    <!-- Body -->
    <div class="card-body-inner">
      <p class="banner-subtitle">@banner.SubTitle</p>
      <h3 class="banner-title">@banner.Title</h3>
      <p class="banner-desc">@banner.Description</p>

      <div class="meta-row">
        @if (!string.IsNullOrEmpty(banner.ImageUrl))
        {
          <span class="meta-chip">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            Görsel var
          </span>
        }
        @if (!string.IsNullOrEmpty(banner.VideoUrl))
        {
          <span class="meta-chip">
            <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
            Video var
          </span>
        }
      </div>

      <hr class="divider" />

      <div class="action-row">
        <span class="id-text">ID: @banner.BannerId</span>
        <div class="action-btns">
          <a href="/Admin/Banner/EditBanner/@banner.BannerId" class="action-btn btn-edit">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Düzenle
          </a>
          <button class="action-btn btn-del" onclick="confirmDelete('@banner.BannerId')">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6l-1 14H6L5 6"/>
              <path d="M10 11v6M14 11v6"/>
              <path d="M9 6V4h6v2"/>
            </svg>
            Sil
          </button>
        </div>
      </div>

    </div>
  </div>
}

<script>
  function confirmDelete(id) {
    if (confirm('Banner silinecek. Emin misiniz?')) {
      window.location.href = `/Admin/Banner/DeleteBanner/${id}`;
    }
  }
</script>
