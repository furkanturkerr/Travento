@model Project3Travelin.Dtos.BannerDtos.UpdateBannerDto

@{
    Layout = "~/Views/Admin/Index.cshtml";
    ViewData["Title"] = "Banner Düzenle";
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 16px rgba(13,158,143,.10); --radius: 14px;
  }

  .page-breadcrumb { margin-bottom: 28px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; font-weight: 500; }
  .breadcrumb-item.active { color: var(--muted); }

  .edit-grid { display: grid; grid-template-columns: 1fr 360px; gap: 24px; align-items: start; }
  @@media (max-width: 900px) { .edit-grid { grid-template-columns: 1fr; } }

  .form-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; margin-bottom: 20px; }
  .card-head { padding: 16px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .card-head-icon { width: 34px; height: 34px; background: var(--teal-light); border-radius: 9px; display: flex; align-items: center; justify-content: center; color: var(--teal); flex-shrink: 0; }
  .card-head h5 { margin: 0; font-size: 14px; font-weight: 700; color: var(--text); }
  .card-head p  { margin: 0; font-size: 12px; color: var(--muted); }
  .card-body { padding: 22px; }

  .field-group { margin-bottom: 18px; }
  .field-group:last-child { margin-bottom: 0; }
  .field-group label { display: block; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .form-control-custom { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 9px; font-size: 14px; color: var(--text); background: #fafdfd; transition: border-color .2s, box-shadow .2s; outline: none; box-sizing: border-box; }
  .form-control-custom:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,158,143,.12); background: #fff; }
  textarea.form-control-custom { resize: vertical; min-height: 90px; }
  .text-danger { font-size: 12px; }

  .preview-hero {
    position: relative; border-radius: 12px; overflow: hidden;
    height: 260px; background: #0a1628;
  }
  .preview-hero img { width: 100%; height: 100%; object-fit: cover; opacity: .72; display: block; }
  .preview-hero .overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,.3), rgba(0,0,0,.55));
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 20px;
  }
  .p-subtitle { color: rgba(255,255,255,.8); font-size: 11px; font-weight: 700; letter-spacing: .08em; margin-bottom: 8px; }
  .p-title { color: #fff; font-size: 20px; font-weight: 900; margin: 0 0 10px; text-shadow: 0 2px 8px rgba(0,0,0,.5); line-height: 1.2; }
  .p-desc { color: rgba(255,255,255,.7); font-size: 11px; line-height: 1.5; margin: 0; }
  .play-btn {
    width: 50px; height: 50px; border-radius: 50%;
    background: var(--teal); border: 3px solid rgba(255,255,255,.4);
    display: flex; align-items: center; justify-content: center;
    margin: 8px auto; box-shadow: 0 0 0 8px rgba(13,158,143,.2);
  }
  .play-btn svg { color: #fff; margin-left: 2px; }
  .p-empty {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; color: rgba(255,255,255,.2);
  }

  .btn-submit { width: 100%; padding: 13px; background: var(--teal); color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background .2s, transform .15s; box-shadow: 0 4px 14px rgba(13,158,143,.3); }
  .btn-submit:hover { background: var(--teal-dark); transform: translateY(-1px); }
  .btn-cancel { width: 100%; padding: 11px; background: transparent; color: var(--muted); border: 1.5px solid var(--border); border-radius: 10px; font-size: 14px; font-weight: 600; text-align: center; text-decoration: none; display: block; margin-top: 10px; transition: border-color .2s, color .2s; }
  .btn-cancel:hover { border-color: var(--danger); color: var(--danger); }
</style>

<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item"><a href="/Admin/Banner">Banner Alanı</a></li>
    <li class="breadcrumb-item active">Düzenle</li>
  </ol>
  <a href="/Admin/Banner" class="btn-cancel" style="width:auto;display:inline-block;padding:9px 18px;margin:0;">← Geri Dön</a>
</nav>

<form asp-action="EditBanner" asp-controller="Banner" asp-area="Admin" method="post">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="BannerId" />

  <div class="edit-grid">

    <!-- SOL -->
    <div>

      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </div>
          <div><h5>Metin Bilgileri</h5><p>Banner üzerindeki yazılar</p></div>
        </div>
        <div class="card-body">
          <div class="field-group">
            <label asp-for="SubTitle">Alt Başlık</label>
            <input asp-for="SubTitle" class="form-control-custom"
                   placeholder="Örn: Maceran Burada Başlıyor"
                   oninput="updateSubtitle(this.value)" />
            <span asp-validation-for="SubTitle" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="Title">Ana Başlık</label>
            <input asp-for="Title" class="form-control-custom"
                   placeholder="Örn: Hayalini Kurduğun Yolculuk Seni Bekliyor"
                   oninput="updateTitle(this.value)" />
            <span asp-validation-for="Title" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="Description">Açıklama</label>
            <textarea asp-for="Description" class="form-control-custom"
                      placeholder="Kısa açıklama metni..."
                      oninput="updateDesc(this.value)"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
          </div>
        </div>
      </div>

      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <div><h5>Medya</h5><p>Arka plan görseli ve video linki</p></div>
        </div>
        <div class="card-body">
          <div class="field-group">
            <label asp-for="ImageUrl">Arka Plan Görseli URL</label>
            <input asp-for="ImageUrl" class="form-control-custom"
                   placeholder="https://..."
                   oninput="updateImage(this.value)" />
            <span asp-validation-for="ImageUrl" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="VideoUrl">Video URL <span style="font-weight:400;color:var(--muted);">(isteğe bağlı)</span></label>
            <input asp-for="VideoUrl" class="form-control-custom"
                   placeholder="https://youtube.com/..."
                   oninput="updateVideo(this.value)" />
            <span asp-validation-for="VideoUrl" class="text-danger"></span>
          </div>
        </div>
      </div>

    </div>

    <!-- SAĞ: ÖNİZLEME -->
    <div>
      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div><h5>Canlı Önizleme</h5><p>Sitedeki görünüm</p></div>
        </div>
        <div class="card-body" style="padding:16px;">
          <div class="preview-hero">
            <img id="prevImg" src="@Model.ImageUrl" alt=""
                 style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")" />
            <div class="overlay">
              <p class="p-subtitle" id="prevSubtitle">@Model.SubTitle</p>
              <h3 class="p-title" id="prevTitle">@Model.Title</h3>
              <div class="play-btn" id="prevPlay"
                   style="@(string.IsNullOrEmpty(Model.VideoUrl) ? "display:none;" : "display:flex;")">
                <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              </div>
              <p class="p-desc" id="prevDesc">@Model.Description</p>
            </div>
            @if (string.IsNullOrEmpty(Model.ImageUrl))
            {
              <div class="p-empty" id="prevEmpty">
                <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <span style="font-size:12px;">Görsel bekleniyor</span>
              </div>
            }
            else
            {
              <div class="p-empty" id="prevEmpty" style="display:none;"></div>
            }
          </div>
        </div>
      </div>

      <button type="submit" class="btn-submit">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Değişiklikleri Kaydet
      </button>
      <a href="/Admin/Banner" class="btn-cancel">İptal Et</a>
    </div>

  </div>
</form>

<script>
  function updateImage(url) {
    const img = document.getElementById('prevImg');
    const empty = document.getElementById('prevEmpty');
    if (url && url.startsWith('http')) {
      img.src = url; img.style.display = 'block';
      empty.style.display = 'none';
    } else {
      img.style.display = 'none';
      empty.style.display = 'flex';
    }
  }

  function updateVideo(url) {
    document.getElementById('prevPlay').style.display = url ? 'flex' : 'none';
  }

  function updateSubtitle(val) { document.getElementById('prevSubtitle').textContent = val || 'Alt Başlık'; }
  function updateTitle(val)    { document.getElementById('prevTitle').textContent    = val || 'Ana Başlık'; }
  function updateDesc(val)     { document.getElementById('prevDesc').textContent     = val || 'Açıklama metni...'; }
</script>
