@model List<Project3Travelin.Dtos.FaqDtos.ResultFaqDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
    ViewData["Title"] = "SSS";
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --warning: #f39c12;
    --yellow: #f0c93a; --yellow-light: #fffbea;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 12px rgba(13,158,143,.08); --radius: 12px;
  }

  .page-breadcrumb { margin-bottom: 24px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; }
  .breadcrumb-item.active { color: var(--muted); }

  .btn-add {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--teal); color: #fff; border: none;
    padding: 10px 20px; border-radius: 8px;
    font-weight: 700; font-size: 14px; cursor: pointer;
    transition: background .2s, transform .15s; text-decoration: none;
    box-shadow: 0 4px 14px rgba(13,158,143,.25);
  }
  .btn-add:hover { background: var(--teal-dark); transform: translateY(-1px); color: #fff; }

  /* Stats bar */
  .stats-bar {
    background: var(--white); border-radius: var(--radius);
    border: 1px solid var(--border); box-shadow: var(--shadow);
    padding: 16px 24px; margin-bottom: 20px;
    display: flex; align-items: center; gap: 24px;
  }
  .stat-item { display: flex; align-items: center; gap: 8px; }
  .stat-icon { width: 34px; height: 34px; border-radius: 8px; background: var(--teal-light); display: flex; align-items: center; justify-content: center; color: var(--teal); }
  .stat-val { font-size: 20px; font-weight: 900; color: var(--text); line-height: 1; }
  .stat-lbl { font-size: 11px; color: var(--muted); }

  /* Empty */
  .empty-card {
    background: var(--white); border-radius: var(--radius);
    border: 2px dashed var(--border);
    padding: 72px 32px; text-align: center; color: var(--muted);
  }
  .empty-card svg { opacity: .2; margin-bottom: 16px; }
  .empty-card h5 { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
  .empty-card p  { font-size: 13px; margin-bottom: 20px; }

  /* FAQ list */
  .faq-list { display: flex; flex-direction: column; gap: 10px; }

  .faq-item {
    background: var(--white); border-radius: var(--radius);
    border: 1px solid var(--border); box-shadow: var(--shadow);
    overflow: hidden; transition: box-shadow .2s, transform .15s;
  }
  .faq-item:hover { box-shadow: 0 6px 24px rgba(13,158,143,.12); transform: translateY(-1px); }
  .faq-item.open { border-color: var(--yellow); }
  .faq-item.open .faq-head { background: var(--yellow); }
  .faq-item.open .faq-head .q-text { color: var(--text); }
  .faq-item.open .faq-head .toggle-icon { transform: rotate(180deg); color: var(--text); }

  .faq-head {
    padding: 16px 20px;
    display: flex; align-items: center; gap: 14px;
    cursor: pointer; user-select: none;
    transition: background .2s;
  }
  .faq-head:hover { background: var(--teal-light); }
  .faq-item.open .faq-head:hover { background: var(--yellow); }

  .q-num {
    width: 28px; height: 28px; border-radius: 7px;
    background: var(--teal-light); color: var(--teal);
    font-size: 12px; font-weight: 800;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .faq-item.open .q-num { background: rgba(0,0,0,.1); color: var(--text); }

  .q-text { flex: 1; font-size: 14px; font-weight: 700; color: var(--text); margin: 0; }
  .toggle-icon { flex-shrink: 0; color: var(--muted); transition: transform .25s, color .2s; }

  .faq-body { display: none; padding: 0 20px 18px; }
  .faq-body.show { display: block; }
  .faq-answer { font-size: 13px; color: var(--muted); line-height: 1.7; margin: 0 0 16px; padding-top: 4px; }

  .faq-footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 12px; border-top: 1px solid var(--border);
  }
  .id-text { font-size: 11px; color: var(--muted); font-family: monospace; }

  .action-btns { display: flex; gap: 6px; }
  .action-btn {
    width: 30px; height: 30px; border-radius: 7px; border: none;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .15s, transform .15s; text-decoration: none;
  }
  .action-btn svg { width: 14px; height: 14px; }
  .btn-edit { background: #fff8e6; color: var(--warning); }
  .btn-del  { background: #fdecea; color: var(--danger); }
  .btn-edit:hover { background: var(--warning); color: #fff; transform: scale(1.1); }
  .btn-del:hover  { background: var(--danger);  color: #fff; transform: scale(1.1); }
</style>

<!-- Breadcrumb -->
<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item active">SSS</li>
  </ol>
  <a href="/Admin/Faq/CreateFaq" class="btn-add">
    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Soru Ekle
  </a>
</nav>

<!-- Stats -->
@if (Model.Any())
{
  <div class="stats-bar">
    <div class="stat-item">
      <div class="stat-icon">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </div>
      <div>
        <div class="stat-val">@Model.Count</div>
        <div class="stat-lbl">Toplam Soru</div>
      </div>
    </div>
  </div>
}

<!-- FAQ List -->
@if (!Model.Any())
{
  <div class="empty-card">
    <svg width="52" height="52" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10"/>
      <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
      <line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
    <h5>Henüz soru eklenmedi</h5>
    <p>Sık sorulan sorular bölümünü buradan yönetin.</p>
    <a href="/Admin/Faq/CreateFaq" class="btn-add" style="display:inline-flex;">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Soru Ekle
    </a>
  </div>
}
else
{
  <div class="faq-list">
    @{ int idx = 0; }
    @foreach (var item in Model)
    {
      idx++;
      <div class="faq-item" id="faq-@item.FaqId">
        <div class="faq-head" onclick="toggleFaq('@item.FaqId')">
          <span class="q-num">@idx</span>
          <p class="q-text">@item.Question</p>
          <svg class="toggle-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
        <div class="faq-body" id="body-@item.FaqId">
          <p class="faq-answer">@item.Answer</p>
          <div class="faq-footer">
            <span class="id-text">ID: @item.FaqId</span>
            <div class="action-btns">
              <a href="/Admin/Faq/EditFaq/@item.FaqId" class="action-btn btn-edit" title="Düzenle">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
              </a>
              <button class="action-btn btn-del" title="Sil" onclick="confirmDelete('@item.FaqId')">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14H6L5 6"/>
                  <path d="M10 11v6M14 11v6"/>
                  <path d="M9 6V4h6v2"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}

<script>
  function toggleFaq(id) {
    const item = document.getElementById('faq-' + id);
    const body = document.getElementById('body-' + id);
    const isOpen = item.classList.contains('open');
    // close all
    document.querySelectorAll('.faq-item').forEach(el => el.classList.remove('open'));
    document.querySelectorAll('.faq-body').forEach(el => el.classList.remove('show'));
    // open clicked if it was closed
    if (!isOpen) {
      item.classList.add('open');
      body.classList.add('show');
    }
  }

  function confirmDelete(id) {
    if (confirm('Bu soru silinecek. Emin misiniz?')) {
      window.location.href = `/Admin/Faq/DeleteFaq/${id}`;
    }
  }
</script>
