@model Project3Travelin.Dtos.FaqDtos.UpdateFaqDto

@{
    Layout = "~/Views/Admin/Index.cshtml";
    ViewData["Title"] = "Soru Düzenle";
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --yellow: #f0c93a;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 16px rgba(13,158,143,.10); --radius: 14px;
  }

  .page-breadcrumb { margin-bottom: 28px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; font-weight: 500; }
  .breadcrumb-item.active { color: var(--muted); }

  .edit-grid { display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start; }
  @@media (max-width: 900px) { .edit-grid { grid-template-columns: 1fr; } }

  .form-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; margin-bottom: 20px; }
  .card-head { padding: 16px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .card-head-icon { width: 34px; height: 34px; background: var(--teal-light); border-radius: 9px; display: flex; align-items: center; justify-content: center; color: var(--teal); flex-shrink: 0; }
  .card-head h5 { margin: 0; font-size: 14px; font-weight: 700; color: var(--text); }
  .card-head p  { margin: 0; font-size: 12px; color: var(--muted); }
  .card-body { padding: 22px; }

  .field-group { margin-bottom: 18px; }
  .field-group:last-child { margin-bottom: 0; }
  .field-group label { display: block; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .form-control-custom { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 9px; font-size: 14px; color: var(--text); background: #fafdfd; transition: border-color .2s, box-shadow .2s; outline: none; box-sizing: border-box; }
  .form-control-custom:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,158,143,.12); background: #fff; }
  textarea.form-control-custom { resize: vertical; min-height: 110px; }
  .text-danger { font-size: 12px; }

  .preview-faq { border-radius: 12px; overflow: hidden; border: 1px solid var(--border); }
  .preview-head { padding: 16px 18px; background: var(--yellow); display: flex; align-items: center; gap: 12px; }
  .preview-head .q-num { width: 28px; height: 28px; border-radius: 7px; background: rgba(0,0,0,.1); color: var(--text); font-size: 12px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .preview-head .q-text { flex: 1; font-size: 14px; font-weight: 700; color: var(--text); margin: 0; }
  .preview-body { padding: 16px 18px; background: var(--white); border-top: 1px solid var(--border); }
  .preview-body p { font-size: 13px; color: var(--muted); line-height: 1.7; margin: 0; }

  .btn-submit { width: 100%; padding: 13px; background: var(--teal); color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background .2s, transform .15s; box-shadow: 0 4px 14px rgba(13,158,143,.3); }
  .btn-submit:hover { background: var(--teal-dark); transform: translateY(-1px); }
  .btn-cancel { width: 100%; padding: 11px; background: transparent; color: var(--muted); border: 1.5px solid var(--border); border-radius: 10px; font-size: 14px; font-weight: 600; text-align: center; text-decoration: none; display: block; margin-top: 10px; transition: border-color .2s, color .2s; }
  .btn-cancel:hover { border-color: var(--danger); color: var(--danger); }
</style>

<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item"><a href="/Admin/Faq">SSS</a></li>
    <li class="breadcrumb-item active">Soru Düzenle</li>
  </ol>
  <a href="/Admin/Faq" class="btn-cancel" style="width:auto;display:inline-block;padding:9px 18px;margin:0;">← Geri Dön</a>
</nav>

<form asp-action="EditFaq" asp-controller="Faq" asp-area="Admin" method="post">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="FaqId" />

  <div class="edit-grid">

    <!-- SOL -->
    <div>
      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <div><h5>Soru & Cevap</h5><p>SSS bölümündeki içeriği düzenleyin</p></div>
        </div>
        <div class="card-body">
          <div class="field-group">
            <label asp-for="Question">Soru</label>
            <input asp-for="Question" class="form-control-custom"
                   placeholder="Örn: Tur rezervasyonu nasıl yapılır?"
                   oninput="updateQuestion(this.value)" />
            <span asp-validation-for="Question" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="Answer">Cevap</label>
            <textarea asp-for="Answer" class="form-control-custom"
                      placeholder="Sorunun cevabını buraya yazın..."
                      oninput="updateAnswer(this.value)"></textarea>
            <span asp-validation-for="Answer" class="text-danger"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- SAĞ: ÖNİZLEME -->
    <div>
      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div><h5>Canlı Önizleme</h5><p>Sitedeki görünüm</p></div>
        </div>
        <div class="card-body">
          <div class="preview-faq">
            <div class="preview-head">
              <span class="q-num">?</span>
              <p class="q-text" id="prevQuestion">@Model.Question</p>
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="flex-shrink:0;color:#666;">
                <polyline points="18 15 12 9 6 15"/>
              </svg>
            </div>
            <div class="preview-body">
              <p id="prevAnswer">@Model.Answer</p>
            </div>
          </div>
        </div>
      </div>

      <button type="submit" class="btn-submit">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Değişiklikleri Kaydet
      </button>
      <a href="/Admin/Faq" class="btn-cancel">İptal Et</a>
    </div>

  </div>
</form>

<script>
  function updateQuestion(val) {
    document.getElementById('prevQuestion').textContent = val || 'Soru...';
  }

  function updateAnswer(val) {
    document.getElementById('prevAnswer').textContent = val || 'Cevap...';
  }
</script>
