@model List<Project3Travelin.Dtos.TourTineraryDtos.ResultTineraryListByTourIdDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
    ViewData["Title"] = "Güzergah Listesi";
    var tours = ViewBag.Tours as List<Project3Travelin.Dtos.TourDtos.ResultTourDto>;
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --warning: #f39c12; --success: #27ae60;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 12px rgba(13,158,143,.08); --radius: 12px;
  }

  .page-breadcrumb { margin-bottom: 24px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; }
  .breadcrumb-item.active { color: var(--muted); }

  .btn-add {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--teal); color: #fff; border: none;
    padding: 10px 20px; border-radius: 8px;
    font-weight: 700; font-size: 14px; cursor: pointer;
    transition: background .2s, transform .15s; text-decoration: none;
    box-shadow: 0 4px 14px rgba(13,158,143,.25);
  }
  .btn-add:hover { background: var(--teal-dark); transform: translateY(-1px); color: #fff; }

  /* Empty */
  .empty-card {
    background: var(--white); border-radius: var(--radius);
    border: 2px dashed var(--border);
    padding: 72px 32px; text-align: center; color: var(--muted);
  }
  .empty-card svg { opacity: .2; margin-bottom: 16px; }
  .empty-card h5 { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
  .empty-card p  { font-size: 13px; margin-bottom: 20px; }

  /* Itinerary card */
  .itin-card {
    background: var(--white); border-radius: var(--radius);
    border: 1px solid var(--border); box-shadow: var(--shadow);
    overflow: hidden; margin-bottom: 18px;
    transition: box-shadow .2s;
  }
  .itin-card:hover { box-shadow: 0 6px 24px rgba(13,158,143,.12); }

  .itin-header {
    padding: 16px 22px;
    background: var(--teal-light);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .itin-header-left { display: flex; align-items: center; gap: 12px; }
  .itin-icon {
    width: 38px; height: 38px; background: var(--teal); border-radius: 9px;
    display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0;
  }
  .itin-tour-name { font-size: 15px; font-weight: 800; color: var(--text); }
  .itin-id { font-size: 11px; color: var(--muted); font-family: monospace; margin-top: 2px; }

  .day-count-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--teal); color: #fff;
    border-radius: 20px; padding: 4px 12px;
    font-size: 12px; font-weight: 700; flex-shrink: 0;
  }

  /* Days accordion */
  .days-list { padding: 0; }
  .day-item {
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .day-item:last-child { border-bottom: none; }

  .day-header {
    padding: 14px 22px;
    display: flex; align-items: center; gap: 12px;
    cursor: pointer; transition: background .15s;
    user-select: none;
  }
  .day-header:hover { background: #f7fbfb; }

  .day-num {
    width: 28px; height: 28px; border-radius: 7px;
    background: var(--teal-light); color: var(--teal);
    font-size: 12px; font-weight: 900;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .day-title { font-size: 14px; font-weight: 700; color: var(--text); flex: 1; }
  .day-chevron {
    color: var(--muted); transition: transform .2s; flex-shrink: 0;
  }
  .day-item.open .day-chevron { transform: rotate(180deg); }

  .day-body {
    display: none; padding: 0 22px 16px 62px;
    font-size: 13px; color: var(--muted); line-height: 1.7;
  }
  .day-item.open .day-body { display: block; }

  /* Footer */
  .itin-footer {
    padding: 14px 22px;
    border-top: 1px solid var(--border);
    background: #fafefe;
    display: flex; align-items: center; justify-content: space-between;
  }
  .itin-footer-id { font-size: 11px; color: var(--muted); font-family: monospace; }

  .action-btns { display: flex; gap: 8px; }
  .action-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 8px; border: none;
    font-size: 12px; font-weight: 700; cursor: pointer;
    transition: background .15s, transform .15s; text-decoration: none;
  }
  .action-btn svg { width: 13px; height: 13px; }
  .btn-edit { background: #fff8e6; color: var(--warning); }
  .btn-edit:hover { background: var(--warning); color: #fff; transform: translateY(-1px); }
  .btn-del  { background: #fdecea; color: var(--danger); }
  .btn-del:hover  { background: var(--danger);  color: #fff; transform: translateY(-1px); }
</style>

<!-- Breadcrumb -->
<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item active">Güzergah Listesi</li>
  </ol>
  <a href="/Admin/TourItinerary/CreateItinerary" class="btn-add">
    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Güzergah Ekle
  </a>
</nav>

@if (Model == null || !Model.Any())
{
  <div class="empty-card">
    <svg width="52" height="52" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
      <path d="M3 12h18M3 6h18M3 18h18"/>
    </svg>
    <h5>Henüz güzergah eklenmedi</h5>
    <p>Tur güzergahlarını buradan yönetin.</p>
    <a href="/Admin/TourItinerary/CreateTourItinerary" class="btn-add" style="display:inline-flex;">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Güzergah Ekle
    </a>
  </div>
}
else
{
  @foreach (var itin in Model)
  {
    <div class="itin-card">

      <!-- Header -->
      <div class="itin-header">
        <div class="itin-header-left">
          <div class="itin-icon">
            <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M3 12h18M3 6h18M3 18h12"/>
            </svg>
          </div>
          <div>
            @{
              var tourName = tours?.FirstOrDefault(t => t.TourId == itin.TourId)?.Title;
            }
            <div class="itin-tour-name">@(tourName ?? itin.TourId)</div>
            <div class="itin-id">ID: @itin.ItineraryId</div>
          </div>
        </div>
        <span class="day-count-chip">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          @(itin.Days != null ? itin.Days.Count : 0) Gün
        </span>
      </div>

      <!-- Days -->
      @if (itin.Days != null && itin.Days.Any())
      {
        <div class="days-list">
          @foreach (var day in itin.Days.OrderBy(d => d.DayNumber))
          {
            <div class="day-item" onclick="toggleDay(this)">
              <div class="day-header">
                <span class="day-num">@day.DayNumber</span>
                <span class="day-title">@day.Title</span>
                <svg class="day-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </div>
              <div class="day-body">@day.Description</div>
            </div>
          }
        </div>
      }
      else
      {
        <div style="padding:18px 22px; color:var(--muted); font-size:13px;">Gün bilgisi eklenmemiş.</div>
      }

      <!-- Footer -->
      <div class="itin-footer">
        <span class="itin-footer-id">@itin.ItineraryId</span>
        <div class="action-btns">
          <a href="/Admin/TourItinerary/EditTourItinerary/@itin.ItineraryId" class="action-btn btn-edit">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Düzenle
          </a>
          <button class="action-btn btn-del" onclick="confirmDelete('@itin.ItineraryId'); event.stopPropagation();">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6l-1 14H6L5 6"/>
              <path d="M10 11v6M14 11v6"/>
              <path d="M9 6V4h6v2"/>
            </svg>
            Sil
          </button>
        </div>
      </div>

    </div>
  }
}

<script>
  function toggleDay(el) {
    el.classList.toggle('open');
  }
  function confirmDelete(id) {
    if (confirm('Bu güzergah silinecek. Emin misiniz?')) {
      window.location.href = `/Admin/TourItinerary/DeleteItinerary/${id}`;
    }
  }
</script>
