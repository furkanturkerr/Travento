@model Project3Travelin.Dtos.InstagramDtos.CreateInstagramDto

@{
    Layout = "~/Views/Admin/Index.cshtml";
    ViewData["Title"] = "Instagram Galerisi Ekle";
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c;
    --insta1: #f09433; --insta2: #e6683c; --insta3: #dc2743; --insta4: #cc2366; --insta5: #bc1888;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 16px rgba(13,158,143,.10); --radius: 14px;
  }

  .page-breadcrumb { margin-bottom: 28px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; font-weight: 500; }
  .breadcrumb-item.active { color: var(--muted); }

  .edit-grid { display: grid; grid-template-columns: 1fr 380px; gap: 24px; align-items: start; }
  @@media (max-width: 1000px) { .edit-grid { grid-template-columns: 1fr; } }

  .form-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; margin-bottom: 20px; }
  .card-head { padding: 16px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .card-head-icon { width: 34px; height: 34px; background: var(--teal-light); border-radius: 9px; display: flex; align-items: center; justify-content: center; color: var(--teal); flex-shrink: 0; }
  .card-head h5 { margin: 0; font-size: 14px; font-weight: 700; color: var(--text); }
  .card-head p  { margin: 0; font-size: 12px; color: var(--muted); }
  .card-body { padding: 22px; }

  .field-group { margin-bottom: 16px; }
  .field-group:last-child { margin-bottom: 0; }
  .field-group label { display: block; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .form-control-custom { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 9px; font-size: 14px; color: var(--text); background: #fafdfd; transition: border-color .2s, box-shadow .2s; outline: none; box-sizing: border-box; }
  .form-control-custom:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,158,143,.12); background: #fff; }
  .text-danger { font-size: 12px; }

  /* image inputs grid */
  .img-inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  /* Preview */
  .preview-header {
    background: linear-gradient(135deg, var(--insta1), var(--insta2), var(--insta3), var(--insta4), var(--insta5));
    padding: 14px 18px; border-radius: 12px 12px 0 0;
    display: flex; align-items: center; gap: 8px;
  }
  .preview-header svg { color: #fff; }
  .preview-header span { color: #fff; font-size: 13px; font-weight: 800; }

  .photo-grid-preview {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px;
    padding: 12px; background: #f7fbfb;
    border: 1px solid var(--border); border-top: none;
    border-radius: 0 0 12px 12px;
  }
  .photo-cell {
    aspect-ratio: 1/1; border-radius: 8px; overflow: hidden;
    background: #e8f0f1; border: 1.5px solid var(--border);
    position: relative;
  }
  .photo-cell img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .photo-cell .cell-num {
    position: absolute; top: 4px; left: 4px;
    background: rgba(0,0,0,.45); color: #fff;
    font-size: 9px; font-weight: 800; padding: 1px 5px; border-radius: 4px;
  }
  .photo-cell .no-img {
    width: 100%; height: 100%; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 3px; color: var(--muted); font-size: 9px; font-weight: 600;
  }
  .photo-cell .no-img svg { opacity: .3; }

  .btn-submit { width: 100%; padding: 13px; background: var(--teal); color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background .2s, transform .15s; box-shadow: 0 4px 14px rgba(13,158,143,.3); margin-top: 20px; }
  .btn-submit:hover { background: var(--teal-dark); transform: translateY(-1px); }
  .btn-cancel { width: 100%; padding: 11px; background: transparent; color: var(--muted); border: 1.5px solid var(--border); border-radius: 10px; font-size: 14px; font-weight: 600; text-align: center; text-decoration: none; display: block; margin-top: 10px; transition: border-color .2s, color .2s; }
  .btn-cancel:hover { border-color: var(--danger); color: var(--danger); }
</style>

<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item"><a href="/Admin/Instagram">Instagram</a></li>
    <li class="breadcrumb-item active">Galeri Ekle</li>
  </ol>
  <a href="/Admin/Instagram" class="btn-cancel" style="width:auto;display:inline-block;padding:9px 18px;margin:0;">← Geri Dön</a>
</nav>

<form asp-action="CreateInstagram" asp-controller="Instagram" asp-area="Admin" method="post">
  @Html.AntiForgeryToken()

  <div class="edit-grid">

    <!-- SOL -->
    <div>

      <!-- Profil URL -->
      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <div><h5>Profil Linki</h5><p>Follow butonu için Instagram URL</p></div>
        </div>
        <div class="card-body">
          <div class="field-group">
            <label asp-for="Url">Instagram URL</label>
            <input asp-for="Url" class="form-control-custom" placeholder="https://instagram.com/..." />
            <span asp-validation-for="Url" class="text-danger"></span>
          </div>
        </div>
      </div>

      <!-- Görseller -->
      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <div><h5>Fotoğraflar</h5><p>8 adet Instagram fotoğrafı URL'si</p></div>
        </div>
        <div class="card-body">
          <div class="img-inputs">
            <div class="field-group">
              <label asp-for="Image1">Fotoğraf 1</label>
              <input asp-for="Image1" class="form-control-custom" placeholder="https://..." oninput="updatePreview(1, this.value)" />
              <span asp-validation-for="Image1" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="Image2">Fotoğraf 2</label>
              <input asp-for="Image2" class="form-control-custom" placeholder="https://..." oninput="updatePreview(2, this.value)" />
              <span asp-validation-for="Image2" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="Image3">Fotoğraf 3</label>
              <input asp-for="Image3" class="form-control-custom" placeholder="https://..." oninput="updatePreview(3, this.value)" />
              <span asp-validation-for="Image3" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="Image4">Fotoğraf 4</label>
              <input asp-for="Image4" class="form-control-custom" placeholder="https://..." oninput="updatePreview(4, this.value)" />
              <span asp-validation-for="Image4" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="Image5">Fotoğraf 5</label>
              <input asp-for="Image5" class="form-control-custom" placeholder="https://..." oninput="updatePreview(5, this.value)" />
              <span asp-validation-for="Image5" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="Image6">Fotoğraf 6</label>
              <input asp-for="Image6" class="form-control-custom" placeholder="https://..." oninput="updatePreview(6, this.value)" />
              <span asp-validation-for="Image6" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="Image7">Fotoğraf 7</label>
              <input asp-for="Image7" class="form-control-custom" placeholder="https://..." oninput="updatePreview(7, this.value)" />
              <span asp-validation-for="Image7" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="Image8">Fotoğraf 8</label>
              <input asp-for="Image8" class="form-control-custom" placeholder="https://..." oninput="updatePreview(8, this.value)" />
              <span asp-validation-for="Image8" class="text-danger"></span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- SAĞ: ÖNİZLEME -->
    <div>
      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div><h5>Canlı Önizleme</h5><p>Sitedeki galeri görünümü</p></div>
        </div>
        <div class="card-body" style="padding:16px;">
          <div class="preview-header">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
            <span>Instagram Galerisi</span>
          </div>
          <div class="photo-grid-preview">
            @for (int i = 1; i <= 8; i++)
            {
              <div class="photo-cell">
                <div class="no-img" id="empty@(i)">
                  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                  @i
                </div>
                <img id="img@(i)" src="" alt="" style="display:none;" />
                <span class="cell-num" id="num@(i)" style="display:none;">@i</span>
              </div>
            }
          </div>
        </div>
      </div>

      <button type="submit" class="btn-submit">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Kaydet
      </button>
      <a href="/Admin/Instagram" class="btn-cancel">İptal Et</a>
    </div>

  </div>
</form>

<script>
  function updatePreview(n, url) {
    const img   = document.getElementById('img' + n);
    const empty = document.getElementById('empty' + n);
    const num   = document.getElementById('num' + n);
    if (url && url.startsWith('http')) {
      img.src = url; img.style.display = 'block';
      empty.style.display = 'none';
      num.style.display = 'block';
    } else {
      img.style.display = 'none';
      empty.style.display = 'flex';
      num.style.display = 'none';
    }
  }
</script>
