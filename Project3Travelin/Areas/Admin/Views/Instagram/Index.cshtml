@model List<Project3Travelin.Dtos.InstagramDtos.ResultInstagramDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
    var insta = Model?.FirstOrDefault();
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --warning: #f39c12;
    --insta1: #f09433; --insta2: #e6683c; --insta3: #dc2743; --insta4: #cc2366; --insta5: #bc1888;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 4px 24px rgba(13,158,143,.10); --radius: 16px;
  }

  .page-breadcrumb { margin-bottom: 28px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; }
  .breadcrumb-item.active { color: var(--muted); }

  .btn-add {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--teal); color: #fff; border: none;
    padding: 10px 20px; border-radius: 8px;
    font-weight: 700; font-size: 14px; cursor: pointer;
    transition: background .2s, transform .15s; text-decoration: none;
    box-shadow: 0 4px 14px rgba(13,158,143,.25);
  }
  .btn-add:hover { background: var(--teal-dark); transform: translateY(-1px); color: #fff; }
  .btn-add.disabled { background: #b2d8d4; box-shadow: none; cursor: not-allowed; pointer-events: none; opacity: .7; }

  .info-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--teal-light); color: var(--teal);
    border-radius: 20px; padding: 5px 12px;
    font-size: 12px; font-weight: 600; margin-bottom: 20px;
  }

  /* Empty */
  .empty-card {
    background: var(--white); border-radius: var(--radius);
    border: 2px dashed var(--border);
    padding: 72px 32px; text-align: center; color: var(--muted);
  }
  .empty-card svg { opacity: .2; margin-bottom: 18px; }
  .empty-card h5 { font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .empty-card p  { font-size: 14px; margin-bottom: 24px; }

  /* Main card */
  .insta-card {
    background: var(--white); border-radius: var(--radius);
    box-shadow: var(--shadow); border: 1px solid var(--border);
    overflow: hidden;
  }

  /* Instagram header strip */
  .insta-header {
    padding: 20px 28px;
    background: linear-gradient(135deg, var(--insta1), var(--insta2), var(--insta3), var(--insta4), var(--insta5));
    display: flex; align-items: center; justify-content: space-between;
  }
  .insta-header .brand { display: flex; align-items: center; gap: 10px; }
  .insta-header .brand svg { color: #fff; }
  .insta-header .brand span { color: #fff; font-size: 16px; font-weight: 800; letter-spacing: .02em; }
  .insta-header .url-chip {
    background: rgba(255,255,255,.2); color: #fff;
    border-radius: 20px; padding: 5px 14px;
    font-size: 12px; font-weight: 600; backdrop-filter: blur(4px);
    display: flex; align-items: center; gap: 6px; text-decoration: none;
    transition: background .2s;
  }
  .insta-header .url-chip:hover { background: rgba(255,255,255,.35); }

  /* Photo grid */
  .photo-section { padding: 24px 28px; }
  .photo-section h6 { font-size: 12px; font-weight: 700; color: var(--muted); letter-spacing: .08em; text-transform: uppercase; margin-bottom: 14px; }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 8px;
  }
  @@media (max-width: 1100px) { .photo-grid { grid-template-columns: repeat(4, 1fr); } }
  @@media (max-width: 600px)  { .photo-grid { grid-template-columns: repeat(2, 1fr); } }

  .photo-cell {
    aspect-ratio: 1/1;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    background: #e8f0f1;
    border: 2px solid var(--border);
  }
  .photo-cell img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .3s;
  }
  .photo-cell:hover img { transform: scale(1.07); }
  .photo-cell .cell-num {
    position: absolute; top: 6px; left: 6px;
    background: rgba(0,0,0,.45); color: #fff;
    font-size: 10px; font-weight: 800;
    padding: 2px 7px; border-radius: 5px;
    backdrop-filter: blur(3px);
  }
  .photo-cell .no-img {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 4px; color: var(--muted); font-size: 10px; font-weight: 600;
  }
  .photo-cell .no-img svg { opacity: .3; }

  /* Footer */
  .card-footer-inner {
    padding: 16px 28px;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .id-text { font-size: 11px; color: var(--muted); font-family: monospace; }

  .action-btns { display: flex; gap: 10px; }
  .action-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 18px; border-radius: 9px; border: none;
    font-size: 13px; font-weight: 700; cursor: pointer;
    transition: background .15s, transform .15s; text-decoration: none;
  }
  .action-btn svg { width: 15px; height: 15px; }
  .btn-edit { background: #fff8e6; color: var(--warning); }
  .btn-edit:hover { background: var(--warning); color: #fff; transform: translateY(-1px); }
  .btn-del  { background: #fdecea; color: var(--danger); }
  .btn-del:hover  { background: var(--danger); color: #fff; transform: translateY(-1px); }
</style>

<!-- Breadcrumb -->
<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item active">Instagram</li>
  </ol>

  @if (insta == null)
  {
    <a href="/Admin/Instagram/CreateInstagram" class="btn-add">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Galeri Ekle
    </a>
  }
  else
  {
    <span class="btn-add disabled">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Galeri Ekle
    </span>
  }
</nav>

<div class="info-chip">
  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
    <circle cx="12" cy="12" r="10"/>
    <line x1="12" y1="8" x2="12" y2="12"/>
    <line x1="12" y1="16" x2="12.01" y2="16"/>
  </svg>
  Bu bölümde yalnızca 1 galeri tanımlanabilir.
</div>

@if (insta == null)
{
  <div class="empty-card">
    <svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
      <rect x="2" y="2" width="20" height="20" rx="5"/>
      <circle cx="12" cy="12" r="4"/>
      <circle cx="17.5" cy="6.5" r="1"/>
    </svg>
    <h5>Henüz galeri eklenmedi</h5>
    <p>Instagram fotoğraf galerisi bölümünü buradan yönetin.</p>
    <a href="/Admin/Instagram/CreateInstagram" class="btn-add" style="display:inline-flex;">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Galeri Ekle
    </a>
  </div>
}
else
{
  <div class="insta-card">

    <!-- Header -->
    <div class="insta-header">
      <div class="brand">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        <span>Instagram Galerisi</span>
      </div>
      @if (!string.IsNullOrEmpty(insta.Url))
      {
        <a href="@insta.Url" target="_blank" class="url-chip">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Profili Görüntüle
        </a>
      }
    </div>

    <!-- Photos -->
    <div class="photo-section">
      <h6>Fotoğraflar (8 adet)</h6>
      <div class="photo-grid">
        @{
          var images = new[] { insta.Image1, insta.Image2, insta.Image3, insta.Image4, insta.Image5, insta.Image6, insta.Image7, insta.Image8 };
        }
        @for (int i = 0; i < 8; i++)
        {
          <div class="photo-cell">
            @if (!string.IsNullOrEmpty(images[i]))
            {
              <img src="@images[i]" alt="Fotoğraf @(i+1)" />
              <span class="cell-num">@(i+1)</span>
            }
            else
            {
              <div class="no-img">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                @(i+1)
              </div>
            }
          </div>
        }
      </div>
    </div>

    <!-- Footer -->
    <div class="card-footer-inner">
      <span class="id-text">ID: @insta.InstagramId</span>
      <div class="action-btns">
        <a href="/Admin/Instagram/EditInstagram/@insta.InstagramId" class="action-btn btn-edit">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
          Düzenle
        </a>
        <button class="action-btn btn-del" onclick="confirmDelete('@insta.InstagramId')">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14H6L5 6"/>
            <path d="M10 11v6M14 11v6"/>
            <path d="M9 6V4h6v2"/>
          </svg>
          Sil
        </button>
      </div>
    </div>

  </div>
}

<script>
  function confirmDelete(id) {
    if (confirm('Instagram galerisi silinecek. Emin misiniz?')) {
      window.location.href = `/Admin/Instagram/DeleteInstagram/${id}`;
    }
  }
</script>
