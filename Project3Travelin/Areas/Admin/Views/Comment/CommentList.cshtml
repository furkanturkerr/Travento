@model List<Project3Travelin.Dtos.CommantDtos.ResultCommentDto>

@{
Layout = "~/Views/Admin/Index.cshtml";
ViewData["Title"] = "Yorumlar";
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --warning: #f39c12; --success: #27ae60;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 12px rgba(13,158,143,.08); --radius: 12px;
    --yellow: #f5a623;
  }
  .page-breadcrumb { margin-bottom: 24px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; }
  .breadcrumb-item.active { color: var(--muted); }
  .stats-row { display: flex; gap: 14px; margin-bottom: 22px; flex-wrap: wrap; }
  .stat-card { background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); box-shadow: var(--shadow); padding: 14px 20px; display: flex; align-items: center; gap: 12px; flex: 1; min-width: 130px; }
  .stat-icon { width: 34px; height: 34px; border-radius: 9px; background: var(--teal-light); display: flex; align-items: center; justify-content: center; color: var(--teal); flex-shrink: 0; }
  .stat-icon.warn { background: #fff8e6; color: var(--warning); }
  .stat-icon.suc  { background: #eafaf1; color: var(--success); }
  .stat-val { font-size: 20px; font-weight: 900; color: var(--text); line-height: 1; }
  .stat-lbl { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .table-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; }
  .table-toolbar { padding: 14px 18px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .search-box { display: flex; align-items: center; gap: 8px; background: #f4f8f8; border: 1.5px solid var(--border); border-radius: 8px; padding: 7px 12px; flex: 1; min-width: 200px; }
  .search-box input { border: none; background: transparent; outline: none; font-size: 13px; color: var(--text); width: 100%; }
  .search-box svg { color: var(--muted); flex-shrink: 0; }
  .filter-select { padding: 8px 12px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 13px; font-weight: 600; color: var(--text); background: #f4f8f8; outline: none; cursor: pointer; }
  .filter-select:focus { border-color: var(--teal); }
  .row-count { font-size: 12px; color: var(--muted); margin-left: auto; white-space: nowrap; }
  .data-table { width: 100%; border-collapse: collapse; }
  .data-table thead tr { background: #f4f8f8; }
  .data-table th { padding: 11px 16px; text-align: left; font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; border-bottom: 1px solid var(--border); white-space: nowrap; cursor: pointer; user-select: none; }
  .data-table th:hover { color: var(--teal); }
  .data-table th.sort-asc::after  { content: ' ↑'; color: var(--teal); }
  .data-table th.sort-desc::after { content: ' ↓'; color: var(--teal); }
  .data-table tbody tr { border-bottom: 1px solid var(--border); transition: background .12s; }
  .data-table tbody tr:last-child { border-bottom: none; }
  .data-table tbody tr:hover { background: #f9fdfd; }
  .data-table td { padding: 12px 16px; font-size: 13px; color: var(--text); vertical-align: middle; }
  .td-headline { font-weight: 700; max-width: 160px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .td-detail   { color: var(--muted); max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .status-chip { display: inline-flex; align-items: center; gap: 4px; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 700; white-space: nowrap; }
  .status-chip.approved { background: #eafaf1; color: var(--success); }
  .status-chip.pending  { background: #fff8e6; color: var(--warning); }
  .action-btns { display: flex; gap: 5px; }
  .action-btn { width: 28px; height: 28px; border-radius: 6px; border: none; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: background .12s, transform .12s; text-decoration: none; }
  .action-btn svg { width: 13px; height: 13px; }
  .btn-approve { background: #eafaf1; color: var(--success); }
  .btn-approve:hover { background: var(--success); color: #fff; transform: scale(1.1); }
  .btn-reject  { background: #fff8e6; color: var(--warning); }
  .btn-reject:hover  { background: var(--warning); color: #fff; transform: scale(1.1); }
  .btn-del     { background: #fdecea; color: var(--danger); }
  .btn-del:hover     { background: var(--danger); color: #fff; transform: scale(1.1); }
  .table-footer { padding: 12px 18px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
  .page-info { font-size: 12px; color: var(--muted); }
  .page-btns { display: flex; gap: 4px; }
  .page-btn { min-width: 30px; height: 30px; border-radius: 7px; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; cursor: pointer; color: var(--text); background: #f4f8f8; border: 1.5px solid var(--border); padding: 0 6px; transition: all .12s; }
  .page-btn:hover { background: var(--teal-light); border-color: var(--teal); color: var(--teal); }
  .page-btn.active { background: var(--teal); color: #fff; border-color: var(--teal); }
  .page-btn.disabled { opacity: .35; cursor: not-allowed; pointer-events: none; }
  .empty-row td { text-align: center; padding: 48px; color: var(--muted); font-size: 13px; }
</style>

<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item active">Yorumlar</li>
  </ol>
</nav>

@if (Model != null && Model.Any())
{
<div class="stats-row">
  <div class="stat-card">
    <div class="stat-icon">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </div>
    <div><div class="stat-val">@Model.Count</div><div class="stat-lbl">Toplam</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon suc">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <div><div class="stat-val">@Model.Count(c => c.IsStatus)</div><div class="stat-lbl">Onaylı</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon warn">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    </div>
    <div><div class="stat-val">@Model.Count(c => !c.IsStatus)</div><div class="stat-lbl">Bekleyen</div></div>
  </div>
</div>
}

<div class="table-card">
  <div class="table-toolbar">
    <div class="search-box">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="searchInput" placeholder="Başlık veya yorum ara..." oninput="applyFilters()" />
    </div>
    <select class="filter-select" id="statusFilter" onchange="applyFilters()">
      <option value="all">Tüm Durumlar</option>
      <option value="approved">Onaylı</option>
      <option value="pending">Bekleyen</option>
    </select>
    <span class="row-count" id="rowCount"></span>
  </div>

  <div style="overflow-x:auto;">
    <table class="data-table">
      <thead>
      <tr>
        <th onclick="sortTable('headline')">Başlık</th>
        <th onclick="sortTable('detail')">Yorum</th>

        <th onclick="sortTable('date')">Tarih</th>
        <th onclick="sortTable('status')">Durum</th>
        <th>İşlem</th>
      </tr>
      </thead>
      <tbody id="tableBody">
      @if (Model == null || !Model.Any())
      {
      <tr class="empty-row"><td colspan="6">Henüz yorum yok.</td></tr>
      }
      else
      {
      @foreach (var c in Model.OrderByDescending(x => x.CommentDate))
      {
      <tr data-status="@(c.IsStatus ? "approved" : "pending")"
          data-headline="@c.Headline?.ToLower()"
          data-detail="@c.CommentDetail?.ToLower()"
          data-date="@c.CommentDate">
        <td class="td-headline" title="@c.Headline">@c.Headline</td>
        <td class="td-detail"   title="@c.CommentDetail">@c.CommentDetail</td>
        <td style="white-space:nowrap;color:var(--muted);">@c.CommentDate.ToString("dd.MM.yyyy")</td>
        <td>
                <span class="status-chip @(c.IsStatus ? "approved" : "pending")">
                  @(c.IsStatus ? "✓ Onaylı" : "⏳ Bekliyor")
                </span>
        </td>
        <td>
          <div class="action-btns">
            @if (!c.IsStatus)
            {
            <a href="/Admin/Comment/ApproveComment/@c.CommentId" class="action-btn btn-approve" title="Onayla">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </a>
            }
            else
            {
            <a href="/Admin/Comment/ApproveComment/@c.CommentId" class="action-btn btn-reject" title="Geri Al">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </a>
            }
            <button class="action-btn btn-del" title="Sil" onclick="confirmDelete('@c.CommentId')">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
            </button>
          </div>
        </td>
      </tr>
      }
      }
      </tbody>
    </table>
  </div>

  <div class="table-footer">
    <span class="page-info" id="pageInfo"></span>
    <div class="page-btns" id="pageBtns"></div>
  </div>
</div>

<script>
  var PAGE_SIZE = 20;
  var currentPage = 1;
  var sortCol = 'date';
  var sortDir = 'desc';
  var filteredRows = [];

  function getAllRows() {
    return Array.from(document.querySelectorAll('#tableBody tr[data-status]'));
  }

  function applyFilters() {
    var search = document.getElementById('searchInput').value.toLowerCase().trim();
    var status = document.getElementById('statusFilter').value;


    filteredRows = getAllRows().filter(function(row) {
      var matchSearch = !search ||
        (row.dataset.headline || '').includes(search) ||
        (row.dataset.detail   || '').includes(search);
      var matchStatus = status === 'all' || row.dataset.status === status;

      return matchSearch && matchStatus;
    });

    currentPage = 1;
    renderTable();
  }

  function sortTable(col) {
    if (sortCol === col) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    else { sortCol = col; sortDir = 'asc'; }

    document.querySelectorAll('.data-table th').forEach(function(th) {
      th.classList.remove('sort-asc', 'sort-desc');
    });
    var thMap = { headline: 0, detail: 1, date: 2, status: 3 };
    var th = document.querySelectorAll('.data-table th')[thMap[col]];
    if (th) th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');

    filteredRows.sort(function(a, b) {
      var av, bv;
      if      (col === 'date')     { av = a.dataset.date || '';     bv = b.dataset.date || ''; }
      else if (col === 'status')   { av = a.dataset.status || '';   bv = b.dataset.status || ''; }
      else if (col === 'headline') { av = a.dataset.headline || ''; bv = b.dataset.headline || ''; }
      else                         { av = a.dataset.detail || '';   bv = b.dataset.detail || ''; }

      if (av < bv) return sortDir === 'asc' ? -1 : 1;
      if (av > bv) return sortDir === 'asc' ?  1 : -1;
      return 0;
    });

    renderTable();
  }

  function renderTable() {
    var total = filteredRows.length;
    var totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;

    var start = (currentPage - 1) * PAGE_SIZE;
    var end   = Math.min(start + PAGE_SIZE, total);

    getAllRows().forEach(function(r) { r.style.display = 'none'; });
    filteredRows.forEach(function(r, i) {
      r.style.display = (i >= start && i < end) ? '' : 'none';
    });

    var allCount = getAllRows().length;
    document.getElementById('rowCount').textContent =
      total + ' yorum' + (total !== allCount ? ' (filtrelenmiş ' + allCount + ' / ' + total + ')' : '');

    document.getElementById('pageInfo').textContent =
      total === 0 ? 'Sonuç yok' : (start + 1) + '–' + end + ' arası, toplam ' + total + ' yorum';

    var btns = '';
    btns += '<span class="page-btn ' + (currentPage === 1 ? 'disabled' : '') + '" onclick="goPage(' + (currentPage-1) + ')">' +
      '<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></span>';
    for (var p = 1; p <= totalPages; p++) {
      if (p === 1 || p === totalPages || (p >= currentPage - 1 && p <= currentPage + 1)) {
        btns += '<span class="page-btn ' + (p === currentPage ? 'active' : '') + '" onclick="goPage(' + p + ')">' + p + '</span>';
      } else if (p === currentPage - 2 || p === currentPage + 2) {
        btns += '<span class="page-btn" style="pointer-events:none;border:none;background:none;">…</span>';
      }
    }
    btns += '<span class="page-btn ' + (currentPage === totalPages ? 'disabled' : '') + '" onclick="goPage(' + (currentPage+1) + ')">' +
      '<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>';
    document.getElementById('pageBtns').innerHTML = btns;
  }

  function goPage(p) { currentPage = p; renderTable(); }

  function confirmDelete(id) {
    if (confirm('Bu yorum silinecek. Emin misiniz?')) {
      window.location.href = '/Admin/Comment/DeleteComment/' + id;
    }
  }

  filteredRows = getAllRows();
  renderTable();
</script>
