@model List<Project3Travelin.Dtos.PopulerDtos.ResultPopulerDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
    int count = 0;
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --warning: #f39c12;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 12px rgba(13,158,143,.08); --radius: 12px;
  }

  .page-breadcrumb { margin-bottom: 24px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; }
  .breadcrumb-item.active { color: var(--muted); }

  .btn-add {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--teal); color: #fff; border: none;
    padding: 10px 20px; border-radius: 8px;
    font-weight: 700; font-size: 14px; cursor: pointer;
    transition: background .2s, transform .15s; text-decoration: none;
    box-shadow: 0 4px 14px rgba(13,158,143,.25);
  }
  .btn-add:hover { background: var(--teal-dark); transform: translateY(-1px); color: #fff; }

  /* ── Card grid ── */
  .populer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
  }

  .place-card {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: transform .2s, box-shadow .2s;
  }
  .place-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(13,158,143,.14);
  }

  /* Image area */
  .card-img-wrap {
    position: relative;
    height: 180px;
    overflow: hidden;
    background: #111;
  }
  .card-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover; opacity: .88;
    transition: transform .3s, opacity .3s;
  }
  .place-card:hover .card-img-wrap img {
    transform: scale(1.05); opacity: 1;
  }
  .card-img-wrap .img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.7) 0%, transparent 55%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 14px 14px 12px;
  }
  .card-img-wrap .city-name {
    color: #fff; font-size: 18px; font-weight: 900;
    text-shadow: 0 2px 6px rgba(0,0,0,.5); margin: 0; line-height: 1.1;
  }
  .card-img-wrap .country-name {
    color: #f0c93a; font-size: 11px; font-weight: 700;
    letter-spacing: .05em; margin-bottom: 2px;
    text-shadow: 0 1px 4px rgba(0,0,0,.4);
  }
  .card-num {
    position: absolute; top: 10px; left: 10px;
    background: rgba(0,0,0,.45); color: #fff;
    font-size: 11px; font-weight: 800; letter-spacing: .04em;
    padding: 3px 8px; border-radius: 6px;
    backdrop-filter: blur(4px);
  }

  /* Card footer */
  .card-footer-inner {
    padding: 12px 14px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .card-footer-inner .meta { font-size: 12px; color: var(--muted); }
  .card-footer-inner .meta strong { color: var(--text); font-size: 13px; display: block; }

  .action-btns { display: flex; gap: 6px; }
  .action-btn {
    width: 30px; height: 30px; border-radius: 7px; border: none;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .15s, transform .15s; text-decoration: none;
  }
  .action-btn svg { width: 14px; height: 14px; }
  .btn-edit { background: #fff8e6; color: var(--warning); }
  .btn-del  { background: #fdecea; color: var(--danger); }
  .btn-edit:hover { background: var(--warning); color: #fff; transform: scale(1.1); }
  .btn-del:hover  { background: var(--danger);  color: #fff; transform: scale(1.1); }

  /* Empty state */
  .empty-card {
    grid-column: 1 / -1;
    background: var(--white); border-radius: var(--radius);
    border: 2px dashed var(--border);
    padding: 64px 32px; text-align: center; color: var(--muted);
  }
  .empty-card svg { opacity: .2; margin-bottom: 16px; }
  .empty-card h5 { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
  .empty-card p  { font-size: 13px; margin-bottom: 20px; }
</style>

<!-- Breadcrumb -->
<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item active">Popüler Yerler</li>
  </ol>
  <a href="~/Admin/PopulerTour/CreatePopulerTour" class="btn-add">
    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Yer Ekle
  </a>
</nav>

<!-- Grid -->
<div class="populer-grid">

  @if (!Model.Any())
  {
    <div class="empty-card">
      <svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
        <circle cx="12" cy="9" r="2.5"/>
      </svg>
      <h5>Henüz yer eklenmedi</h5>
      <p>Popüler yerler bölümünde gösterilecek destinasyonları buradan yönetin.</p>
      <a href="~/Admin/PopulerTour/CreatePopulerTour" class="btn-add" style="display:inline-flex;">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Yer Ekle
      </a>
    </div>
  }

  @foreach (var item in Model)
  {
    count++;
    <div class="place-card">
      <div class="card-img-wrap">
        <img src="@item.ImageUrl" alt="@item.City" />
        <div class="img-overlay">
          <div class="country-name">@item.Country</div>
          <h4 class="city-name">@item.City</h4>
        </div>
        <span class="card-num">#@count</span>
      </div>
      <div class="card-footer-inner">
        <div class="meta">
          <strong>@item.City</strong>
          @item.Country
        </div>
        <div class="action-btns">
          <a href="/Admin/PopulerTour/EditPopulerTour/@item.PopulerId" class="action-btn btn-edit" title="Düzenle">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </a>
          <button class="action-btn btn-del" title="Sil"
                  onclick="confirmDelete('@item.PopulerId')">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6l-1 14H6L5 6"/>
              <path d="M10 11v6M14 11v6"/>
              <path d="M9 6V4h6v2"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  }

</div>

<script>
  function confirmDelete(id) {
    if (confirm('Bu yer silinecek. Emin misiniz?')) {
      window.location.href = `/Admin/PopulerTour/DeletePopulerTour/${id}`;
    }
  }
</script>