@model Project3Travelin.Dtos.AboutDtos.UpdateAboutDto

@{
    Layout = "~/Views/Admin/Index.cshtml";
    ViewData["Title"] = "Hakkımızda Düzenle";
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 16px rgba(13,158,143,.10); --radius: 14px;
  }

  .page-breadcrumb { margin-bottom: 28px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; font-weight: 500; }
  .breadcrumb-item.active { color: var(--muted); }

  .edit-grid { display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start; }
  @@media (max-width: 900px) { .edit-grid { grid-template-columns: 1fr; } }

  .form-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; margin-bottom: 20px; }
  .card-head { padding: 16px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .card-head-icon { width: 34px; height: 34px; background: var(--teal-light); border-radius: 9px; display: flex; align-items: center; justify-content: center; color: var(--teal); flex-shrink: 0; }
  .card-head h5 { margin: 0; font-size: 14px; font-weight: 700; color: var(--text); }
  .card-head p  { margin: 0; font-size: 12px; color: var(--muted); }
  .card-body { padding: 22px; }

  .field-group { margin-bottom: 18px; }
  .field-group:last-child { margin-bottom: 0; }
  .field-group label { display: block; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .form-control-custom { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 9px; font-size: 14px; color: var(--text); background: #fafdfd; transition: border-color .2s, box-shadow .2s; outline: none; box-sizing: border-box; }
  .form-control-custom:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,158,143,.12); background: #fff; }
  textarea.form-control-custom { resize: vertical; min-height: 110px; }
  .text-danger { font-size: 12px; }

  .preview-wrap {
    position: relative; border-radius: 14px; overflow: hidden;
    height: 240px; background: #0a1628; margin-bottom: 12px;
  }
  .preview-wrap .p-img1 { width: 100%; height: 100%; object-fit: cover; opacity: .75; display: block; }
  .preview-wrap .p-img2 {
    position: absolute; bottom: 12px; right: 12px;
    width: 38%; border-radius: 10px; overflow: hidden;
    border: 3px solid #fff; box-shadow: 0 6px 20px rgba(0,0,0,.3);
  }
  .preview-wrap .p-img2 img { width: 100%; height: 90px; object-fit: cover; display: block; }
  .preview-wrap .p-badge {
    position: absolute; top: 50%; left: 18px;
    transform: translateY(-50%) rotate(-90deg);
    background: rgba(13,158,143,.9); color: #fff;
    font-size: 10px; font-weight: 800; letter-spacing: .1em;
    padding: 4px 12px; border-radius: 20px; white-space: nowrap;
  }
  .preview-wrap .p-empty {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; color: rgba(255,255,255,.2);
  }
  .preview-text .p-title { font-size: 16px; font-weight: 900; color: var(--text); margin: 0 0 6px; }
  .preview-text .p-detail { font-size: 12px; color: var(--muted); line-height: 1.6; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .btn-submit { width: 100%; padding: 13px; background: var(--teal); color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background .2s, transform .15s; box-shadow: 0 4px 14px rgba(13,158,143,.3); }
  .btn-submit:hover { background: var(--teal-dark); transform: translateY(-1px); }
  .btn-cancel { width: 100%; padding: 11px; background: transparent; color: var(--muted); border: 1.5px solid var(--border); border-radius: 10px; font-size: 14px; font-weight: 600; text-align: center; text-decoration: none; display: block; margin-top: 10px; transition: border-color .2s, color .2s; }
  .btn-cancel:hover { border-color: var(--danger); color: var(--danger); }
</style>

<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item"><a href="/Admin/About">Hakkımızda</a></li>
    <li class="breadcrumb-item active">Düzenle</li>
  </ol>
  <a href="/Admin/About" class="btn-cancel" style="width:auto;display:inline-block;padding:9px 18px;margin:0;">← Geri Dön</a>
</nav>

<form asp-action="EditAbout" asp-controller="About" asp-area="Admin" method="post">
  <input type="hidden" asp-for="AboutId" />

  <div class="edit-grid">

    <!-- SOL -->
    <div>

      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </div>
          <div><h5>Temel Bilgiler</h5><p>Başlık ve açıklama metni</p></div>
        </div>
        <div class="card-body">
          <div class="field-group">
            <label asp-for="Title">Başlık</label>
            <input asp-for="Title" class="form-control-custom"
                   placeholder="Örn: Yeni Yerler Keşfet, Büyük Deneyimler Yaşa"
                   oninput="updateTitle(this.value)" />
            <span asp-validation-for="Title" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="AboutDetail">Açıklama</label>
            <textarea asp-for="AboutDetail" class="form-control-custom"
                      placeholder="Hakkımızda metni..."
                      oninput="updateDetail(this.value)"></textarea>
            <span asp-validation-for="AboutDetail" class="text-danger"></span>
          </div>
        </div>
      </div>

      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <div><h5>Görseller</h5><p>Ana görsel ve küçük kart görseli</p></div>
        </div>
        <div class="card-body">
          <div class="field-group">
            <label asp-for="Image1">Ana Görsel URL</label>
            <input asp-for="Image1" class="form-control-custom" placeholder="https://..."
                   oninput="updateImg1(this.value)" />
            <span asp-validation-for="Image1" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="Image2">Küçük Kart Görseli URL</label>
            <input asp-for="Image2" class="form-control-custom" placeholder="https://..."
                   oninput="updateImg2(this.value)" />
            <span asp-validation-for="Image2" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="ImageTitle">Görsel Etiketi</label>
            <input asp-for="ImageTitle" class="form-control-custom"
                   placeholder="Örn: 25 Yıllık Deneyim"
                   oninput="updateBadge(this.value)" />
            <span asp-validation-for="ImageTitle" class="text-danger"></span>
          </div>
        </div>
      </div>

    </div>

    <!-- SAĞ: ÖNİZLEME -->
    <div>
      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div><h5>Canlı Önizleme</h5><p>Sitedeki görünüm</p></div>
        </div>
        <div class="card-body">

          <div class="preview-wrap">
            <img class="p-img1" id="prevImg1" src="@Model.Image1" alt=""
                 style="@(string.IsNullOrEmpty(Model.Image1) ? "display:none;" : "")" />
            <div class="p-img2" id="prevImg2Wrap"
                 style="@(string.IsNullOrEmpty(Model.Image2) ? "display:none;" : "")">
              <img id="prevImg2" src="@Model.Image2" alt="" />
            </div>
            @if (!string.IsNullOrEmpty(Model.ImageTitle))
            {
              <span class="p-badge" id="prevBadge">@Model.ImageTitle</span>
            }
            else
            {
              <span class="p-badge" id="prevBadge" style="display:none;">Etiket</span>
            }
            @if (string.IsNullOrEmpty(Model.Image1))
            {
              <div class="p-empty" id="prevEmpty">
                <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <span style="font-size:12px;">Görsel bekleniyor</span>
              </div>
            }
            else
            {
              <div class="p-empty" id="prevEmpty" style="display:none;"></div>
            }
          </div>

          <div class="preview-text">
            <p class="p-title" id="prevTitle">@Model.Title</p>
            <p class="p-detail" id="prevDetail">@Model.AboutDetail</p>
          </div>

        </div>
      </div>

      <button type="submit" class="btn-submit">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Değişiklikleri Kaydet
      </button>
      <a href="/Admin/About" class="btn-cancel">İptal Et</a>
    </div>

  </div>
</form>

<script>
  function updateImg1(url) {
    const img = document.getElementById('prevImg1');
    const empty = document.getElementById('prevEmpty');
    if (url && url.startsWith('http')) {
      img.src = url; img.style.display = 'block';
      empty.style.display = 'none';
    } else {
      img.style.display = 'none';
      empty.style.display = 'flex';
    }
  }

  function updateImg2(url) {
    const wrap = document.getElementById('prevImg2Wrap');
    const img  = document.getElementById('prevImg2');
    if (url && url.startsWith('http')) {
      img.src = url; wrap.style.display = 'block';
    } else {
      wrap.style.display = 'none';
    }
  }

  function updateBadge(val) {
    const el = document.getElementById('prevBadge');
    if (val) { el.textContent = val; el.style.display = 'block'; }
    else      { el.style.display = 'none'; }
  }

  function updateTitle(val)  { document.getElementById('prevTitle').textContent  = val || 'Başlık'; }
  function updateDetail(val) { document.getElementById('prevDetail').textContent = val || 'Açıklama metni...'; }
</script>
