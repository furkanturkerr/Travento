@model List<Project3Travelin.Dtos.AboutDtos.ResultAboutDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
    var about = Model?.FirstOrDefault();
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --warning: #f39c12;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 4px 24px rgba(13,158,143,.10); --radius: 16px;
  }

  .page-breadcrumb { margin-bottom: 28px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; }
  .breadcrumb-item.active { color: var(--muted); }

  .btn-add {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--teal); color: #fff; border: none;
    padding: 10px 20px; border-radius: 8px;
    font-weight: 700; font-size: 14px; cursor: pointer;
    transition: background .2s, transform .15s; text-decoration: none;
    box-shadow: 0 4px 14px rgba(13,158,143,.25);
  }
  .btn-add:hover { background: var(--teal-dark); transform: translateY(-1px); color: #fff; }
  .btn-add.disabled { background: #b2d8d4; box-shadow: none; cursor: not-allowed; pointer-events: none; opacity: .7; }

  /* ── Empty ── */
  .empty-card {
    background: var(--white); border-radius: var(--radius);
    border: 2px dashed var(--border);
    padding: 72px 32px; text-align: center; color: var(--muted);
  }
  .empty-card svg { opacity: .2; margin-bottom: 18px; }
  .empty-card h5 { font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .empty-card p  { font-size: 14px; margin-bottom: 24px; }

  /* ── About card ── */
  .about-card {
    background: var(--white); border-radius: var(--radius);
    box-shadow: var(--shadow); border: 1px solid var(--border);
    overflow: hidden;
  }

  /* Hero images area */
  .hero-area {
    padding: 28px 28px 0;
    background: #f7fbfb;
    display: flex;
    gap: 16px;
    align-items: flex-end;
    position: relative;
  }
  .img-card-main {
    flex: 1;
    border-radius: 18px 18px 0 0;
    overflow: hidden;
    height: 300px;
    position: relative;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
  }
  .img-card-main img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .img-card-main .img-title-badge {
    position: absolute; top: 50%; left: -14px;
    transform: translateY(-50%) rotate(-90deg);
    background: var(--teal); color: #fff;
    font-size: 11px; font-weight: 800; letter-spacing: .12em;
    padding: 7px 20px; border-radius: 30px;
    white-space: nowrap;
    box-shadow: 0 4px 18px rgba(13,158,143,.5);
    z-index: 3;
  }
  .img-card-secondary {
    width: 38%;
    border-radius: 18px 18px 0 0;
    overflow: hidden;
    height: 200px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    flex-shrink: 0;
  }
  .img-card-secondary img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  /* Body */
  .card-body-inner { padding: 28px 32px; }

  .about-title {
    font-size: 22px; font-weight: 900; color: var(--text);
    margin: 0 0 10px; line-height: 1.2;
  }
  .about-detail {
    font-size: 14px; color: var(--muted); line-height: 1.7;
    margin: 0 0 20px;
    display: -webkit-box; -webkit-line-clamp: 3;
    -webkit-box-orient: vertical; overflow: hidden;
  }

  .meta-row {
    display: flex; align-items: center; gap: 12px;
    flex-wrap: wrap; margin-bottom: 24px;
  }
  .meta-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--teal-light); color: var(--teal);
    border-radius: 20px; padding: 4px 12px;
    font-size: 12px; font-weight: 700;
  }

  .divider { border: none; border-top: 1px solid var(--border); margin: 0 0 20px; }

  .action-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }

  .action-btns { display: flex; gap: 10px; }
  .action-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 18px; border-radius: 9px; border: none;
    font-size: 13px; font-weight: 700; cursor: pointer;
    transition: background .15s, transform .15s; text-decoration: none;
  }
  .action-btn svg { width: 15px; height: 15px; flex-shrink: 0; }
  .btn-edit { background: #fff8e6; color: var(--warning); }
  .btn-edit:hover { background: var(--warning); color: #fff; transform: translateY(-1px); }
  .btn-del  { background: #fdecea; color: var(--danger); }
  .btn-del:hover  { background: var(--danger); color: #fff; transform: translateY(-1px); }

  .id-text { font-size: 11px; color: var(--muted); font-family: monospace; }

  /* info chip */
  .info-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--teal-light); color: var(--teal);
    border-radius: 20px; padding: 5px 12px;
    font-size: 12px; font-weight: 600; margin-bottom: 20px;
  }
</style>

<!-- Breadcrumb -->
<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item active">Hakkımızda</li>
  </ol>

  @if (about == null)
  {
    <a href="/Admin/About/CreateAbout" class="btn-add">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      İçerik Ekle
    </a>
  }
  else
  {
    <span class="btn-add disabled" title="Yalnızca 1 içerik eklenebilir">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      İçerik Ekle
    </span>
  }
</nav>

<!-- Info chip -->
<div class="info-chip mb-3">
  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
    <circle cx="12" cy="12" r="10"/>
    <line x1="12" y1="8" x2="12" y2="12"/>
    <line x1="12" y1="16" x2="12.01" y2="16"/>
  </svg>
  Bu bölümde yalnızca 1 içerik tanımlanabilir.
</div>

@if (about == null)
{
  <div class="empty-card">
    <svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="13"/>
      <line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
    <h5>Henüz içerik eklenmedi</h5>
    <p>Hakkımızda bölümünde gösterilecek içeriği buradan yönetin.</p>
    <a href="/Admin/About/CreateAbout" class="btn-add" style="display:inline-flex;">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      İçerik Ekle
    </a>
  </div>
}
else
{
  <div class="about-card">

    <!-- Görseller -->
    <div class="hero-area">
      <div class="img-card-main">
        <img src="@about.Image1" alt="@about.Title" />
        @if (!string.IsNullOrEmpty(about.ImageTitle))
        {
          <span class="img-title-badge">@about.ImageTitle</span>
        }
      </div>
      <div class="img-card-secondary">
        <img src="@about.Image2" alt="@about.Title" />
      </div>
    </div>

    <!-- İçerik -->
    <div class="card-body-inner">
      <h2 class="about-title">@about.Title</h2>
      <p class="about-detail">@about.AboutDetail</p>

      <div class="meta-row">
        <span class="meta-chip">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          2 Görsel
        </span>
        @if (!string.IsNullOrEmpty(about.ImageTitle))
        {
          <span class="meta-chip">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            @about.ImageTitle
          </span>
        }
      </div>

      <hr class="divider" />

      <div class="action-row">
        <span class="id-text">ID: @about.AboutId</span>
        <div class="action-btns">
          <a href="/Admin/About/EditAbout/@about.AboutId" class="action-btn btn-edit">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Düzenle
          </a>
          <button class="action-btn btn-del" onclick="confirmDelete('@about.AboutId')">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6l-1 14H6L5 6"/>
              <path d="M10 11v6M14 11v6"/>
              <path d="M9 6V4h6v2"/>
            </svg>
            Sil
          </button>
        </div>
      </div>

    </div>
  </div>
}

<script>
  function confirmDelete(id) {
    if (confirm('Hakkımızda içeriği silinecek. Emin misiniz?')) {
      window.location.href = `/Admin/About/DeleteAbout/${id}`;
    }
  }
</script>
