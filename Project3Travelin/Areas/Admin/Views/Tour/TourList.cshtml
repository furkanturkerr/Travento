@model List<Project3Travelin.Dtos.TourDtos.ResultTourDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
    ViewData["Title"] = "Tur Listesi";
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --warning: #f39c12; --success: #27ae60;
    --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 12px rgba(13,158,143,.08); --radius: 12px;
  }

  .page-breadcrumb { margin-bottom: 24px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; }
  .breadcrumb-item.active { color: var(--muted); }

  .btn-add {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--teal); color: #fff; border: none;
    padding: 10px 20px; border-radius: 8px;
    font-weight: 700; font-size: 14px; cursor: pointer;
    transition: background .2s, transform .15s; text-decoration: none;
    box-shadow: 0 4px 14px rgba(13,158,143,.25);
  }
  .btn-add:hover { background: var(--teal-dark); transform: translateY(-1px); color: #fff; }

  /* Stats */
  .stats-row { display: flex; gap: 14px; margin-bottom: 22px; flex-wrap: wrap; }
  .stat-card {
    background: var(--white); border-radius: var(--radius);
    border: 1px solid var(--border); box-shadow: var(--shadow);
    padding: 14px 20px; display: flex; align-items: center; gap: 12px;
    flex: 1; min-width: 140px;
  }
  .stat-icon { width: 36px; height: 36px; border-radius: 9px; background: var(--teal-light); display: flex; align-items: center; justify-content: center; color: var(--teal); flex-shrink: 0; }
  .stat-val { font-size: 22px; font-weight: 900; color: var(--text); line-height: 1; }
  .stat-lbl { font-size: 11px; color: var(--muted); margin-top: 2px; }

  /* Empty */
  .empty-card {
    background: var(--white); border-radius: var(--radius);
    border: 2px dashed var(--border);
    padding: 72px 32px; text-align: center; color: var(--muted);
  }
  .empty-card svg { opacity: .2; margin-bottom: 16px; }
  .empty-card h5 { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
  .empty-card p  { font-size: 13px; margin-bottom: 20px; }

  /* Tour grid */
  .tour-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 18px;
  }

  .tour-card {
    background: var(--white); border-radius: var(--radius);
    border: 1px solid var(--border); box-shadow: var(--shadow);
    overflow: hidden; transition: transform .2s, box-shadow .2s;
  }
  .tour-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(13,158,143,.13); }

  /* Image */
  .tc-img {
    position: relative; height: 180px; overflow: hidden; background: #0a1628;
  }
  .tc-img img { width: 100%; height: 100%; object-fit: cover; opacity: .88; transition: transform .3s; display: block; }
  .tour-card:hover .tc-img img { transform: scale(1.05); }
  .tc-img .img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.6) 0%, transparent 50%);
  }
  .tc-price {
    position: absolute; top: 12px; right: 12px;
    background: var(--teal); color: #fff;
    font-size: 13px; font-weight: 800;
    padding: 4px 12px; border-radius: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,.2);
  }
  .tc-location {
    position: absolute; bottom: 12px; left: 12px;
    color: #fff; font-size: 12px; font-weight: 600;
    display: flex; align-items: center; gap: 4px;
    text-shadow: 0 1px 4px rgba(0,0,0,.4);
  }
  .tc-location svg { flex-shrink: 0; }

  /* Body */
  .tc-body { padding: 16px; }
  .tc-title { font-size: 15px; font-weight: 800; color: var(--text); margin: 0 0 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .tc-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
  .tc-chip {
    display: inline-flex; align-items: center; gap: 4px;
    background: var(--teal-light); color: var(--teal);
    border-radius: 6px; padding: 3px 9px;
    font-size: 11px; font-weight: 700;
  }
  .tc-chip.warn { background: #fff8e6; color: var(--warning); }
  .tc-chip.suc  { background: #eafaf1; color: var(--success); }

  .tc-desc { font-size: 12px; color: var(--muted); line-height: 1.6; margin: 0 0 14px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .tc-footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 12px; border-top: 1px solid var(--border);
  }
  .tc-date { font-size: 11px; color: var(--muted); display: flex; align-items: center; gap: 4px; }

  .action-btns { display: flex; gap: 6px; }
  .action-btn {
    width: 30px; height: 30px; border-radius: 7px; border: none;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .15s, transform .15s; text-decoration: none;
  }
  .action-btn svg { width: 14px; height: 14px; }
  .btn-edit   { background: #fff8e6; color: var(--warning); }
  .btn-del    { background: #fdecea; color: var(--danger); }
  .btn-edit:hover { background: var(--warning); color: #fff; transform: scale(1.1); }
  .btn-del:hover  { background: var(--danger);  color: #fff; transform: scale(1.1); }
  .btn-detail { background: var(--teal-light); color: var(--teal); }
  .btn-detail:hover { background: var(--teal); color: #fff; transform: scale(1.1); }
  .btn-itin   { background: #eef4ff; color: #3b82f6; }
  .btn-itin:hover { background: #3b82f6; color: #fff; transform: scale(1.1); }
  .btn-pdf    { background: #fdf3ec; color: #e67e22; }
  .btn-pdf:hover  { background: #e67e22; color: #fff; transform: scale(1.1); }

  /* Pagination */
  .pagination-wrap {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
    margin-top: 28px; padding: 16px 20px;
    background: var(--white); border-radius: var(--radius);
    border: 1px solid var(--border); box-shadow: var(--shadow);
  }
  .page-info { font-size: 13px; color: var(--muted); }
  .page-info strong { color: var(--text); }
  .page-btns { display: flex; align-items: center; gap: 6px; }
  .page-btn {
    min-width: 34px; height: 34px; border-radius: 8px;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; cursor: pointer;
    text-decoration: none; transition: background .15s, color .15s;
    color: var(--text); background: #f4f8f8; border: 1.5px solid var(--border);
    padding: 0 6px;
  }
  .page-btn:hover { background: var(--teal-light); border-color: var(--teal); color: var(--teal); }
  .page-btn.active { background: var(--teal); color: #fff; border-color: var(--teal); }
  .page-btn.disabled { opacity: .35; cursor: not-allowed; pointer-events: none; }
  .page-btn.dots { border: none; background: transparent; cursor: default; pointer-events: none; color: var(--muted); }
</style>

<!-- Breadcrumb -->
<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item active">Tur Listesi</li>
  </ol>
  <a href="/Admin/Tour/CreateTour" class="btn-add">
    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Tur Ekle
  </a>
</nav>

<!-- Stats -->
@if (Model.Any())
{
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </div>
      <div>
        <div class="stat-val">@Model.Count</div>
        <div class="stat-lbl">Toplam Tur</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
        </svg>
      </div>
      <div>
        <div class="stat-val">@Model.Select(t => t.Country).Distinct().Count()</div>
        <div class="stat-lbl">Ülke</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <line x1="12" y1="1" x2="12" y2="23"/>
          <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
      </div>
      <div>
        <div class="stat-val">@Model.Average(t => t.Price).ToString("N0")₺</div>
        <div class="stat-lbl">Ort. Fiyat</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </div>
      <div>
        <div class="stat-val">@Model.Sum(t => t.Capacity)</div>
        <div class="stat-lbl">Top. Kapasite</div>
      </div>
    </div>
  </div>
}

<!-- Tour Grid -->
@if (!Model.Any())
{
  <div class="empty-card">
    <svg width="52" height="52" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>
    <h5>Henüz tur eklenmedi</h5>
    <p>Tur listesi bölümünü buradan yönetin.</p>
    <a href="/Admin/Tour/CreateTour" class="btn-add" style="display:inline-flex;">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Tur Ekle
    </a>
  </div>
}
else
{
  <div class="tour-grid">
    @foreach (var tour in Model)
    {
      <div class="tour-card">
        <div class="tc-img">
          @if (!string.IsNullOrEmpty(tour.ImageUrl))
          {
            <img src="@tour.ImageUrl" alt="@tour.Title" />
          }
          <div class="img-overlay"></div>
          <span class="tc-price">@tour.Price.ToString("N0") ₺</span>
          <span class="tc-location">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
            </svg>
            @tour.City, @tour.Country
          </span>
        </div>

        <div class="tc-body">
          <h4 class="tc-title">@tour.Title</h4>

          <div class="tc-meta">
            @if (!string.IsNullOrEmpty(tour.DayNight))
            {
              <span class="tc-chip">
                <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                @tour.DayNight
              </span>
            }
            <span class="tc-chip suc">
              <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
              </svg>
              @tour.Capacity kişi
            </span>
            <span class="tc-chip warn">
              <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              @tour.TourDate.ToString("dd MMM yyyy")
            </span>
          </div>

          @if (!string.IsNullOrEmpty(tour.Description))
          {
            <p class="tc-desc">@tour.Description</p>
          }

          <div class="tc-footer">
            <span class="tc-date">
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              @tour.TourDate.ToString("dd.MM.yyyy")
            </span>
            <div class="action-btns">
              <!-- PDF Rapor -->
              <a href="/Admin/Tour/TourBookingReport/@tour.TourId" class="action-btn btn-pdf" title="Rezervasyon PDF Raporu">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
              </a>
              <!-- Güzergah -->
              <a href="/Admin/TourItinerary/Index?tourId=@tour.TourId" class="action-btn btn-itin" title="Güzergah">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <line x1="3" y1="12" x2="21" y2="12"/>
                  <line x1="3" y1="18" x2="15" y2="18"/>
                </svg>
              </a>
              <!-- Detay -->
              <a href="/Admin/Tour/DetailTour/@tour.TourId" class="action-btn btn-detail" title="Detay">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </a>
              <!-- Düzenle -->
              <a href="/Admin/Tour/EditTour/@tour.TourId" class="action-btn btn-edit" title="Düzenle">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
              </a>
              <!-- Sil -->
              <button class="action-btn btn-del" title="Sil" onclick="confirmDelete('@tour.TourId')">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14H6L5 6"/>
                  <path d="M10 11v6M14 11v6"/>
                  <path d="M9 6V4h6v2"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}

<!-- Pagination -->
@if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
{
  int currentPage = (int)ViewBag.CurrentPage;
  int totalPages  = (int)ViewBag.TotalPages;
  int totalCount  = (int)ViewBag.TotalCount;

  <div class="pagination-wrap">
    <span class="page-info">
      Toplam <strong>@totalCount</strong> turdan
      <strong>@(((currentPage - 1) * 9) + 1)–@(Math.Min(currentPage * 9, totalCount))</strong> gösteriliyor
    </span>
    <div class="page-btns">
      @if (currentPage > 1)
      {
        <a href="?page=@(currentPage - 1)" class="page-btn">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
      }
      else
      {
        <span class="page-btn disabled">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </span>
      }

      @for (int p = 1; p <= totalPages; p++)
      {
        if (p == currentPage)
        {
          <span class="page-btn active">@p</span>
        }
        else if (p == 1 || p == totalPages || (p >= currentPage - 1 && p <= currentPage + 1))
        {
          <a href="?page=@p" class="page-btn">@p</a>
        }
        else if (p == currentPage - 2 || p == currentPage + 2)
        {
          <span class="page-btn dots">…</span>
        }
      }

      @if (currentPage < totalPages)
      {
        <a href="?page=@(currentPage + 1)" class="page-btn">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      }
      else
      {
        <span class="page-btn disabled">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      }
    </div>
  </div>
}

<script>
  function confirmDelete(id) {
    if (confirm('Bu tur silinecek. Emin misiniz?')) {
      window.location.href = `/Admin/Tour/DeleteTour/${id}`;
    }
  }
</script>
