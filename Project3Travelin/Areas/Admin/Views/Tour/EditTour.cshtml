@model Project3Travelin.Dtos.TourDtos.UpdateTourDto

@{
    Layout = "~/Views/Admin/Index.cshtml";
    ViewData["Title"] = "Tur Düzenle";
}

<style>
  :root {
    --teal: #0d9e8f; --teal-light: #e6f7f5; --teal-dark: #0a7d71;
    --danger: #e74c3c; --text: #1a2e35; --muted: #6b7f86;
    --border: #dde8ea; --white: #fff;
    --shadow: 0 2px 16px rgba(13,158,143,.10); --radius: 14px;
  }
  .page-breadcrumb { margin-bottom: 28px; }
  .breadcrumb-item a { color: var(--teal); text-decoration: none; font-weight: 500; }
  .breadcrumb-item.active { color: var(--muted); }
  .create-grid { display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start; }
  @@media (max-width: 960px) { .create-grid { grid-template-columns: 1fr; } }
  .form-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; margin-bottom: 20px; }
  .card-head { padding: 16px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .card-head-icon { width: 34px; height: 34px; background: var(--teal-light); border-radius: 9px; display: flex; align-items: center; justify-content: center; color: var(--teal); flex-shrink: 0; }
  .card-head h5 { margin: 0; font-size: 14px; font-weight: 700; color: var(--text); }
  .card-head p  { margin: 0; font-size: 12px; color: var(--muted); }
  .card-body { padding: 22px; }
  .field-group { margin-bottom: 16px; }
  .field-group:last-child { margin-bottom: 0; }
  .field-group label { display: block; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .form-control-custom { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 9px; font-size: 14px; color: var(--text); background: #fafdfd; transition: border-color .2s, box-shadow .2s; outline: none; box-sizing: border-box; }
  .form-control-custom:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,158,143,.12); background: #fff; }
  textarea.form-control-custom { resize: vertical; min-height: 90px; }
  .text-danger { font-size: 12px; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .preview-img-wrap { position: relative; border-radius: 12px; overflow: hidden; height: 200px; background: #0a1628; margin-bottom: 14px; }
  .preview-img-wrap img { width: 100%; height: 100%; object-fit: cover; opacity: .82; display: block; }
  .preview-img-wrap .overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.65), transparent 50%); display: flex; flex-direction: column; justify-content: flex-end; padding: 14px 16px; }
  .p-title { color: #fff; font-size: 15px; font-weight: 900; margin: 0 0 4px; text-shadow: 0 2px 6px rgba(0,0,0,.4); }
  .p-loc   { color: rgba(255,255,255,.75); font-size: 11px; }
  .p-price { position: absolute; top: 10px; right: 10px; background: var(--teal); color: #fff; font-size: 12px; font-weight: 800; padding: 3px 10px; border-radius: 20px; }
  .p-empty { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; color: rgba(255,255,255,.2); }
  .preview-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 4px; }
  .preview-chip { display: inline-flex; align-items: center; gap: 4px; background: var(--teal-light); color: var(--teal); border-radius: 6px; padding: 4px 10px; font-size: 11px; font-weight: 700; }
  .btn-submit { width: 100%; padding: 13px; background: var(--teal); color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background .2s, transform .15s; box-shadow: 0 4px 14px rgba(13,158,143,.3); }
  .btn-submit:hover { background: var(--teal-dark); transform: translateY(-1px); }
  .btn-cancel { width: 100%; padding: 11px; background: transparent; color: var(--muted); border: 1.5px solid var(--border); border-radius: 10px; font-size: 14px; font-weight: 600; text-align: center; text-decoration: none; display: block; margin-top: 10px; transition: border-color .2s, color .2s; }
  .btn-cancel:hover { border-color: var(--danger); color: var(--danger); }
</style>

<nav class="page-breadcrumb d-flex align-items-center justify-content-between">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ansayfa</a></li>
    <li class="breadcrumb-item"><a href="/Admin/Tour/TourList">Tur Listesi</a></li>
    <li class="breadcrumb-item active">Tur Düzenle</li>
  </ol>
  <a href="/Admin/Tour/TourList" class="btn-cancel" style="width:auto;display:inline-block;padding:9px 18px;margin:0;">← Geri Dön</a>
</nav>

<form asp-action="EditTour" asp-controller="Tour" asp-area="Admin" method="post">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="TourId" />

  <div class="create-grid">

    <!-- SOL -->
    <div>

      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </div>
          <div><h5>Temel Bilgiler</h5><p>Tur adı ve açıklaması</p></div>
        </div>
        <div class="card-body">
          <div class="field-group">
            <label asp-for="Title">Tur Adı</label>
            <input asp-for="Title" class="form-control-custom" placeholder="Örn: Roma Kültür Turu" oninput="updateTitle(this.value)" />
            <span asp-validation-for="Title" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="Description">Açıklama</label>
            <textarea asp-for="Description" class="form-control-custom" placeholder="Tur hakkında kısa açıklama..."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="WhatAwaits">Sizi Neler Bekliyor</label>
            <textarea asp-for="WhatAwaits" class="form-control-custom" style="min-height:70px;"></textarea>
            <span asp-validation-for="WhatAwaits" class="text-danger"></span>
          </div>
        </div>
      </div>

      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
          </div>
          <div><h5>Konum</h5><p>Ülke ve şehir</p></div>
        </div>
        <div class="card-body">
          <div class="two-col">
            <div class="field-group">
              <label asp-for="Country">Ülke</label>
              <input asp-for="Country" class="form-control-custom" placeholder="Örn: İtalya" oninput="updateLoc()" />
              <span asp-validation-for="Country" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="City">Şehir</label>
              <input asp-for="City" class="form-control-custom" placeholder="Örn: Roma" oninput="updateLoc()" />
              <span asp-validation-for="City" class="text-danger"></span>
            </div>
          </div>
        </div>
      </div>

      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <div><h5>Tur Detayları</h5><p>Fiyat, tarih, kapasite</p></div>
        </div>
        <div class="card-body">
          <div class="two-col">
            <div class="field-group">
              <label asp-for="Price">Fiyat (₺)</label>
              <input asp-for="Price" class="form-control-custom" type="number" oninput="updatePrice(this.value)" />
              <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="Capacity">Kapasite (kişi)</label>
              <input asp-for="Capacity" class="form-control-custom" type="number" oninput="updateCapacity(this.value)" />
              <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>
          </div>
          <div class="two-col">
            <div class="field-group">
              <label asp-for="TourDate">Tur Tarihi</label>
              <input asp-for="TourDate" class="form-control-custom" type="date" oninput="updateDate(this.value)" />
              <span asp-validation-for="TourDate" class="text-danger"></span>
            </div>
            <div class="field-group">
              <label asp-for="DayNight">Gün/Gece</label>
              <input asp-for="DayNight" class="form-control-custom" placeholder="7 Gece 8 Gün" oninput="updateDayNight(this.value)" />
              <span asp-validation-for="DayNight" class="text-danger"></span>
            </div>
          </div>
        </div>
      </div>

      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <div><h5>Medya</h5><p>Görsel, video ve harita</p></div>
        </div>
        <div class="card-body">
          <div class="field-group">
            <label asp-for="ImageUrl">Görsel URL</label>
            <input asp-for="ImageUrl" class="form-control-custom" placeholder="https://..." oninput="updateImage(this.value)" />
            <span asp-validation-for="ImageUrl" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="VideoUrl">Video URL <span style="font-weight:400;color:var(--muted);">(isteğe bağlı)</span></label>
            <input asp-for="VideoUrl" class="form-control-custom" placeholder="https://youtube.com/..." />
            <span asp-validation-for="VideoUrl" class="text-danger"></span>
          </div>
          <div class="field-group">
            <label asp-for="ImageMap">Harita Görseli URL <span style="font-weight:400;color:var(--muted);">(isteğe bağlı)</span></label>
            <input asp-for="ImageMap" class="form-control-custom" placeholder="https://..." />
            <span asp-validation-for="ImageMap" class="text-danger"></span>
          </div>
        </div>
      </div>

    </div>

    <!-- SAĞ -->
    <div>
      <div class="form-card">
        <div class="card-head">
          <div class="card-head-icon">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div><h5>Canlı Önizleme</h5><p>Kart görünümü</p></div>
        </div>
        <div class="card-body">
          <div class="preview-img-wrap">
            <img id="prevImg" src="@Model.ImageUrl" alt=""
                 style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")" />
            <div class="overlay" id="prevOverlay"
                 style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "display:flex;")">
              <p class="p-title" id="prevTitle">@Model.Title</p>
              <p class="p-loc"   id="prevLoc">@Model.City, @Model.Country</p>
            </div>
            <span class="p-price" id="prevPrice"
                  style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")">
              @Model.Price.ToString("N0") ₺
            </span>
            @if (string.IsNullOrEmpty(Model.ImageUrl))
            {
              <div class="p-empty" id="prevEmpty">
                <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <span style="font-size:11px;">Görsel bekleniyor</span>
              </div>
            }
            else
            {
              <div class="p-empty" id="prevEmpty" style="display:none;"></div>
            }
          </div>

          <div class="preview-chips">
            <span class="preview-chip" id="prevDayNight"
                  style="@(string.IsNullOrEmpty(Model.DayNight) ? "display:none;" : "")">@Model.DayNight</span>
            <span class="preview-chip" id="prevCapacity"
                  style="@(Model.Capacity == 0 ? "display:none;" : "")">@Model.Capacity kişi</span>
            <span class="preview-chip" id="prevDate">@Model.TourDate.ToString("dd MMM yyyy")</span>
          </div>
        </div>
      </div>

      <button type="submit" class="btn-submit">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Değişiklikleri Kaydet
      </button>
      <a href="/Admin/Tour/TourList" class="btn-cancel">İptal Et</a>
    </div>

  </div>
</form>

<script>
  function updateImage(url) {
    const img = document.getElementById('prevImg');
    const empty = document.getElementById('prevEmpty');
    const overlay = document.getElementById('prevOverlay');
    const price = document.getElementById('prevPrice');
    if (url && url.startsWith('http')) {
      img.src = url; img.style.display = 'block';
      empty.style.display = 'none'; overlay.style.display = 'flex'; price.style.display = 'block';
    } else {
      img.style.display = 'none'; empty.style.display = 'flex';
      overlay.style.display = 'none'; price.style.display = 'none';
    }
  }
  function updateTitle(val) { document.getElementById('prevTitle').textContent = val || 'Tur Adı'; }
  function updatePrice(val) {
    const el = document.getElementById('prevPrice');
    el.textContent = val ? Number(val).toLocaleString('tr-TR') + ' ₺' : '0 ₺';
  }
  function updateLoc() {
    const c  = document.getElementById('City')?.value || '';
    const co = document.getElementById('Country')?.value || '';
    document.getElementById('prevLoc').textContent = [c, co].filter(Boolean).join(', ') || 'Şehir, Ülke';
  }
  function updateDayNight(val) { const el = document.getElementById('prevDayNight'); el.textContent = val; el.style.display = val ? 'inline-flex' : 'none'; }
  function updateCapacity(val) { const el = document.getElementById('prevCapacity'); el.textContent = val + ' kişi'; el.style.display = val ? 'inline-flex' : 'none'; }
  function updateDate(val) {
    const el = document.getElementById('prevDate');
    if (val) { el.textContent = new Date(val).toLocaleDateString('tr-TR', {day:'2-digit',month:'short',year:'numeric'}); el.style.display = 'inline-flex'; }
    else { el.style.display = 'none'; }
  }
</script>